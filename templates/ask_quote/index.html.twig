{% extends 'base.html.twig' %}

{% block title %}Demande de devis{% endblock %}

{% block body %}
    <section class="inner-banner py-4">
        <div class="container">
            <h2 class="mb-0 text-center fw-bold">Demandez votre devis en ligne</h2>
        </div>
    </section>

    <section class="properties-detail bg-light py-5">
        <div class="container">
            <div class="row justify-content-center">
                {{ form_start(form, {
                    attr: {
                        class: 'form-devis'
                    }
                }) }}
                <div class="col-10 col-xl-10 mx-auto">
                    <div class="devis-card bg-white shadow-sm">

                        <div class="row g-0">
                            <!-- Colonne gauche -->
                            <div class="col-12 col-lg-6 devis-col border-end-lg">
                                <div class="p-4 p-md-5">
                                    <div class="d-flex align-items-center gap-3 mb-4">
                                        <span class="step-badge">11</span>
                                        <h3 class="h3 mb-0 fw-bold text-primary-custom">Vos coordonnées</h3>
                                    </div>
                                    {{ form_row(form.lastName)}}
                                    {{ form_row(form.firstName)}}
                                    {{ form_row(form.address)}}
                                    {{ form_row(form.postalCity)}}
                                    {{ form_row(form.phone)}}
                                    {{ form_row(form.email)}}
                                </div>
                            </div>

                            <!-- Colonne droite -->
                            <div class="col-12 col-lg-6 devis-col">
                                <div class="p-4 p-md-5">
                                    <div class="d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-3 mb-4">
                                        <div class="d-flex align-items-center gap-3">
                                            <span class="step-badge">2.</span>
                                            <h3 class="h3 mb-0 fw-bold text-primary-custom">Votre besoin</h3>
                                        </div>
                                    </div>
                           
                                    <div class="row">
                                    {{ form_row(form.artisanType)}}
                                    {{ form_row(form.projectType)}}
                                    {{ form_row(form.desiredDelay)}} 
                               
                                    </div>

                                    <div class="mb-0">
                                        <div class="row g-2">
                                                {% for choice in form.urgence %}
                                                    <div class="col-6">
                                                        <div class="form-check">
                                                            {{ form_widget(choice) }}
                                                            {{ form_label(choice) }}
                                                        </div>
                                                    </div>
                                                {% endfor %}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Partie basse -->
                        <div class="border-top p-4 p-md-5">
                            <div class="row">
                                <div class="col-12">
                                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2">
                                        <span class="fw-bold fs-5 text-primary-custom">Budget estimatif :</span>
                                        <span class="fw-bold fs-4 text-primary-custom">10 000 €</span>
                                    </div>

                                    {{ form_widget(form.budget)}}

                                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
                                        <span class="fw-bold fs-4 text-primary-custom">500 €</span>
                                        <span class="fw-bold fs-4 text-primary-custom" id="budgetCurrent">Budget : 2 300 €</span>
                                    </div>
                                </div>

                                <div class="col-12 mb-4">
                                    {{ form_widget(form.message)}}
                                </div>

                                <div class="col-12 col-lg-6 mb-4 mb-lg-0">
                                    <div class="upload-box mb-4">
                                        <h4 class="fw-bold mb-2 text-primary-custom">
                                            📷 Ajoutez des photos
                                            <small class="text-muted fw-normal">(fortement recommandé)</small>
                                        </h4>

                                        <p class="mb-3 text-muted">
                                            Les demandes avec photos reçoivent généralement plus de réponses
                                            et permettent aux professionnels de mieux comprendre votre projet.
                                        </p>

                                        {{ form_widget(form.photos) }}
                                        {{ form_errors(form.photos) }}
                                    </div>

                                    <div>
                                        <label class="form-label fw-semibold d-block">Être contacté de préférence par :</label>

                                        <div class="row g-2">
                                            <div class="row g-2">
                                                <div class="col-6 col-sm-4">
                                                    <div class="form-check">
                                                        {{ form_widget(form.contactPhone) }}
                                                        {{ form_label(form.contactPhone) }}
                                                    </div>
                                                </div>

                                                <div class="col-6 col-sm-4">
                                                    <div class="form-check">
                                                        {{ form_widget(form.contactEmail) }}
                                                        {{ form_label(form.contactEmail) }}
                                                    </div>
                                                </div>

                                                <div class="col-6 col-sm-4">
                                                    <div class="form-check">
                                                        {{ form_widget(form.contactSms) }}
                                                        {{ form_label(form.contactSms) }}
                                                    </div>
                                                </div>

                                                <div class="col-6 col-sm-4">
                                                    <div class="form-check">
                                                        {{ form_widget(form.contactChat) }}
                                                        {{ form_label(form.contactChat) }}
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-12 col-lg-6">
                                    
                                    {{ form_row(form.callbackAvailability) }}
                                    {{ form_row(form.interventionMoment) }}
                                    </div>
                                </div>
                            </div>

                            <div class="text-center mt-5">
                                {{ form_row(form.submit) }}

                                <div class="mt-3 fw-semibold text-primary-custom fs-5">
                                    ⭐ 4,8/5 basé sur 120 avis
                                    <span class="text-muted fw-normal">• plus de 2 000 demandes traitées</span>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </section>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const budgetRange = document.getElementById('quote_request_budget');
    const budgetCurrent = document.getElementById('budgetCurrent');

    function formatEuros(value) {
        return new Intl.NumberFormat('fr-FR').format(value) + ' €';
    }

    function updateBudget() {
        const value = budgetRange.value;
        const min = budgetRange.min;
        const max = budgetRange.max;

        budgetCurrent.textContent = 'Budget : ' + formatEuros(value);

        const percent = ((value - min) / (max - min)) * 100;

        budgetRange.style.background =
            `linear-gradient(to right, #0d6efd ${percent}%, #e5e5e5 ${percent}%)`;
    }

    if (budgetRange && budgetCurrent) {
        budgetRange.addEventListener('input', updateBudget);
        updateBudget();
    }

    
});
</script>

    <style>
        .form-devis input[type="text"],
        .form-devis input[type="tel"],
        .form-devis input[type="email"],
        .form-devis textarea {
            background: #FAFAFA;
            padding: clamp(10px, 0.83vw, 10px) clamp(10px, 1.1vw, 10px);
            border-radius: 5px;
            border: 1px solid #0D0D0D;
            font-size: 12px;
            font-weight: 400;
            font-family: "Inter", sans-serif;
            position: relative;
            margin-bottom: 0;
            color: #797D86;
        }

        .properties-detail span {
            font-family: "Inter", sans-serif;
            font-weight: initial;
            font-size: initial;
            line-height: initial;
            margin-bottom: initial;
            margin-right: initial;
            position: initial;
        }

        .selection-devis.form-select {
            padding: clamp(10px, 0.83vw, 10px) clamp(10px, 1.1vw, 10px);
            border-radius: 5px;
            border: 1px solid #0D0D0D;
            font-size: 12px;
            font-weight: 400;
            font-family: "Inter", sans-serif;
            position: relative;
            margin-bottom: 0;
            color: #797D86;
        }
        .selection-devis.form-select:focus {
            border-color: #797D86!important;
            box-shadow: initial;
        }

        .bg-light {
            background: #f0f2f4 !important;
        }

        .devis-card {
            border: 2px solid #A57A5A;
            border-radius: 25px;
            overflow: hidden;
        }

        .text-primary-custom {
            color: #183153;
        }

        .step-badge {
            width: 42px;
            height: 42px;
            border-radius: 10px;
            background: #f7e3a3;
            color: #183153;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 1.5rem;
            flex-shrink: 0;
            margin-bottom: 0!important;
        }

        .next-step-badge {
            background: #eef1f6;
            color: #4b5563;
            border-radius: 8px;
            padding: 10px 14px;
            font-size: 0.95rem;
            white-space: nowrap;
        }

        .form-control,
        .form-select {
            /*min-height: 58px;
            border-radius: 12px;*/  
        }

        .devis-textarea {
            min-height: 140px;
            border-radius: 12px;
            resize: vertical;
        }

        .upload-box {
            border: 1px solid #A57A5A;
            border-radius: 12px;
            background: #f7f9fc;
            padding: 20px;
        }

        .devis-submit-btn {
            min-width: 320px;
            border-radius: 12px;
            background: linear-gradient(180deg, #198754 0%, #157347 100%);
            border: none;
        }

        @media (min-width: 992px) {
            .border-end-lg {
                border-right: 1px solid #A57A5A;
            }
        }

        @media (max-width: 991.98px) {
            .devis-col:first-child {
                border-bottom: 1px solid #A57A5A
            }
        }

        @media (max-width: 575.98px) {
            .devis-submit-btn {
                min-width: 100%;
            }
        }
        .border-top {
            border-top: 1px solid #A57A5A !important;
        }
    </style>
{% endblock %}