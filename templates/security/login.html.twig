<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>Connectez-vous à votre espace personnel</title>

		<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;400;500;600;700;800&display=swap" rel="stylesheet">
		<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200;300;400;500;600;700;800&display=swap" rel="stylesheet">
		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

		<style>
			body {
				background: linear-gradient(180deg, rgba(255, 255, 255, 0.00) 7%, #D0E0FE 100%), url("{{ asset('image/cta/Grid.png') }}") center / cover no-repeat fixed;
				background-color: #F8F7F7;
				min-height: 100vh;
				font-family: Manrope, sans-serif;
			}

			.full-height {
				min-height: 100vh;
				display: flex;
				align-items: center;
				padding: 40px 0;
			}

			.colone-gauche {
				padding-right: 40px;
			}

			.logo img {
				max-width: 180px;
				height: auto;
			}

			.login-art {
				font-family: Manrope, sans-serif;
				font-size: 12px;
				margin-top: 26px;
				display: inline-block;
				letter-spacing: 1px;
			}

			.connection-art-artisanat {
				font-family: "Plus Jakarta Sans", sans-serif;
				font-size: 48px;
				font-weight: 800;
				line-height: 1.15;
				margin-top: 16px;
				margin-bottom: 16px;
			}

			.paragraphe {
				font-family: Manrope, sans-serif;
				font-size: 18px;
				line-height: 1.7;
				max-width: 540px;
			}

			.artisant-h {
				margin-top: 36px;
				flex-wrap: wrap;
				gap: 10px;
			}

			.artisant-h span {
				font-size: 15px;
			}

			.form-login {
				border-radius: 32px;
				background: #FFF;
				padding: 36px;
				max-width: 495px;
				margin: 0 auto;
				box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
			}

			.form-h2 {
				text-align: center;
				font-family: "Plus Jakarta Sans", sans-serif;
				font-size: 36px;
				font-weight: 700;
				margin-bottom: 8px;
			}

			.form-p {
				text-align: center;
				font-family: Manrope, sans-serif;
				margin-bottom: 28px;
				color: #666;
			}

			.form-login input.form-control {
				padding: 13px 12px;
				border-radius: 10px;
				border: 1px solid #E2E2E2;
				margin-bottom: 20px;
				box-shadow: none;
			}

			.form-login input.form-control:focus {
				border-color: #003EC7;
				box-shadow: 0 0 0 0.15rem rgba(0, 62, 199, 0.12);
			}

			.separateur {
				display: flex;
				align-items: center;
				text-align: center;
				margin: 24px 0;
			}

			.separateur::before,
			.separateur::after {
				content: "";
				flex: 1;
				height: 1px;
				background: #E2E2E2;
			}

			.separateur span {
				padding: 0 15px;
				font-size: 14px;
				color: #777;
			}

			.social-buttons {
				display: flex;
				gap: 12px;
				justify-content: center;
				margin-bottom: 24px;
			}

			.google,
			.facebook {
				display: flex;
				width: 100%;
				max-width: 234px;
				padding: 12px;
				justify-content: center;
				align-items: center;
				border-radius: 10px;
				background: #F3F3F4;
				text-decoration: none;
				color: #111;
				font-weight: 600;
				transition: all 0.2s ease;
			}

			.google:hover,
			.facebook:hover {
				background: #e9e9eb;
			}

			.pas-de-compte {
				text-align: center;
				margin-top: 20px;
				margin-bottom: 0;
			}

			.pas-de-compte a {
				text-decoration: none;
				font-weight: 700;
				color: #003EC7;
			}

			.connection {
				border: none;
				border-radius: 12px;
				background: #003EC7;
				box-shadow: 0 20px 25px -5px rgba(0, 62, 199, 0.10), 0 8px 10px -6px rgba(0, 62, 199, 0.10);
				color: #FFF;
				text-align: center;
				font-family: "Plus Jakarta Sans", sans-serif;
				font-size: 16px;
				font-weight: 700;
				line-height: 24px;
				display: flex;
				padding: 16px 0;
				justify-content: center;
				align-items: center;
				width: 100%;
				transition: background 0.2s ease;
			}

			.connection:hover {
				background: #0034a8;
			}

			.mdp {
				color: #003EC7;
				font-family: Manrope, sans-serif;
				font-size: 14px;
				font-weight: 500;
				line-height: 20px;
				text-decoration: none;
			}

			.remember-me {
				font-size: 14px;
				display: flex;
				align-items: center;
				gap: 8px;
			}

			/* TABLET */
			@media(max-width: 991.98px) {
				.full-height {
					padding: 32px 0;
					align-items: flex-start;
				}

				.colone-gauche {
					padding-right: 0;
					margin-bottom: 32px;
					text-align: center;
				}

				.paragraphe {
					max-width: 100%;
					margin-left: auto;
					margin-right: auto;
				}

				.artisant-h {
					justify-content: center;
				}

				.connection-art-artisanat {
					font-size: 40px;
				}
			}

			/* MOBILE */
			@media(max-width: 767.98px) {
				body {
					background-attachment: scroll;
				}

				.full-height {
					padding: 20px 0;
				}

				.connection-art-artisanat {
					font-size: 30px;
				}

				.paragraphe {
					font-size: 16px;
				}

				.form-login {
					padding: 24px 18px;
					border-radius: 22px;
				}

				.form-h2 {
					font-size: 28px;
				}

				.social-buttons {
					flex-direction: column;
					align-items: stretch;
				}

				.google,
				.facebook {
					max-width: 100%;
				}

				.d-flex.justify-content-between.align-items-center.mb-3 {
					flex-direction: column;
					align-items: flex-start !important;
					gap: 12px;
				}

				.logo img {
					max-width: 150px;
				}
			}

			/* PETIT MOBILE */
			@media(max-width: 480px) {
				.connection-art-artisanat {
					font-size: 26px;
				}

				.form-login {
					padding: 20px 16px;
				}

				.login-art {
					font-size: 11px;
				}
			}
		</style>
	</head>

	<body>
		<main class="container-fluid full-height">
			<div class="container">
				<div
					class="row align-items-center g-4">

					<!-- COLONNE GAUCHE -->
					<div class="col-12 col-lg-6 p-3">
						<div class="colone-gauche">
							<div class="logo">
								<img src="{{ asset('image/logo/logo.png') }}" alt="Logo">
							</div>

							<span class="login-art">L'ART DU BÂTI</span>

							<h1 class="connection-art-artisanat">
								Connectez-vous à l'excellence artisanale
							</h1>

							<p class="paragraphe">
								Accédez à une sélection exclusive des meilleurs architectes et artisans.
							</p>

							<div class="artisant-h d-flex align-items-center">
								<img src="{{ asset('image/cta/10.png') }}" class="rounded-circle" style="width:40px; height:40px; object-fit:cover;" alt="Artisan 1">
								<img src="{{ asset('image/cta/11.png') }}" class="rounded-circle" style="width:40px; height:40px; object-fit:cover; margin-left:-20px;" alt="Artisan 2">
								<span class="ms-3">1,200+ artisans vérifiés</span>
							</div>
						</div>
					</div>

					<!-- COLONNE DROITE -->
					<div class="col-12 col-lg-6">
						<div class="form-login">
							<h2 class="form-h2">Connexion</h2>
							<p class="form-p">Veuillez vous connecter</p>

							<form method="post">
								<input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="form-control" autocomplete="email" placeholder="Veuillez entrer votre adresse e-mail" required autofocus>
								<input type="password" name="password" id="inputPassword" class="form-control" autocomplete="current-password" placeholder="Veuillez entrer votre mot de passe" required>
								<input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">
								<div class="d-flex justify-content-between align-items-center mb-3">
									<label class="remember-me">
										<input type="checkbox">
										<span>Se souvenir</span>
									</label>

									<a href="#" class="mdp">
										Mot de passe oublié ?
									</a>
								</div>

								<div class="mb-4">
									<button type="submit" class="connection">
										Se connecter
									</button>
								</div>
							</form>

							<div class="separateur">
								<span>OU</span>
							</div>

							<div class="social-buttons">
								<a href="#" class="google">Google</a>
								<a href="#" class="facebook">Facebook</a>
							</div>

							<p class="pas-de-compte">
								Pas de compte ?
								<a href="{{ path('app_register') }}">Créer</a>
							</p>
						</div>
					</div>

				</div>
			</div>
		</main>

		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
	</body>
</html>
