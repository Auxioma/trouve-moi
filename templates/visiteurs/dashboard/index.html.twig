{% extends 'base.html.twig' %}

{% block title %}Hello DashboardController!{% endblock %}

{% block body %}
<section class="dashboard-lux-banner">
	<div class="container">
		<div class="dashboard-lux-banner-content">
			<div class="dashboard-lux-banner-text">
				<span class="dashboard-lux-kicker">Espace personnel</span>
				<h1>Bienvenue sur votre tableau de bord</h1>
				<p>
					Retrouvez vos échanges, le suivi de vos demandes, vos informations personnelles et toutes vos actions importantes depuis une interface claire, élégante et haut de gamme.
				</p>
			</div>

			<div class="dashboard-lux-banner-actions">
				<a href="#" class="dashboard-lux-btn dashboard-lux-btn-primary">Accéder à la messagerie</a>
				<a href="#" class="dashboard-lux-btn dashboard-lux-btn-outline">Mettre à jour mon profil</a>
			</div>
		</div>
	</div>
</section>

<section class="dashboard-lux-page">
	<div class="container">
		<div class="row g-4">

			<div class="col-xl-3 col-lg-4">
				<aside class="dashboard-lux-sidebar">

					<div class="dashboard-lux-profile-card">
						<div class="dashboard-lux-profile-cover"></div>

						<div class="dashboard-lux-profile-content">
							<div class="dashboard-lux-profile-avatar">
								<img src="https://placehold.co/110x110" alt="Photo de profil">
							</div>

							<h3>Jean Dupont</h3>
							<p class="dashboard-lux-profile-subtitle">Compte personnel actif</p>

							<div class="dashboard-lux-profile-details">
								<div class="dashboard-lux-profile-line">
									<span>Membre depuis</span>
									<strong>Janvier 2026</strong>
								</div>
								<div class="dashboard-lux-profile-line">
									<span>Statut</span>
									<strong>Vérifié</strong>
								</div>
								<div class="dashboard-lux-profile-line">
									<span>Dernière activité</span>
									<strong>Aujourd’hui</strong>
								</div>
							</div>
						</div>
					</div>

					<nav class="dashboard-lux-nav">
						<a href="#" class="dashboard-lux-nav-item active">Accueil</a>
						<a href="#" class="dashboard-lux-nav-item">Messagerie</a>
						<a href="#" class="dashboard-lux-nav-item">Mes demandes</a>
						<a href="#" class="dashboard-lux-nav-item">Mon profil</a>
						<a href="#" class="dashboard-lux-nav-item">Mes documents</a>
						<a href="#" class="dashboard-lux-nav-item">Paramètres</a>
					</nav>

					<div class="dashboard-lux-help-card">
						<span class="dashboard-lux-kicker">Accompagnement</span>
						<h4>Besoin d’aide ?</h4>
						<p>
							Notre équipe vous accompagne dans le suivi de vos demandes et l’utilisation de votre espace personnel.
						</p>
						<a href="#" class="dashboard-lux-btn dashboard-lux-btn-primary w-100">Contacter le support</a>
					</div>

				</aside>
			</div>

			<div class="col-xl-9 col-lg-8">
				<div class="dashboard-lux-main">

					<section class="dashboard-lux-intro-card">
						<div class="dashboard-lux-intro-text">
							<span class="dashboard-lux-kicker">Vue d’ensemble</span>
							<h2>Un espace conçu pour une gestion simple et fluide</h2>
							<p>
								Accédez rapidement à vos informations clés, suivez vos projets en cours et gardez le contrôle sur l’ensemble de votre activité depuis une interface pensée pour la clarté et l’efficacité.
							</p>
						</div>

						<div class="dashboard-lux-completion-card">
							<div class="dashboard-lux-completion-top">
								<span>Complétion du profil</span>
								<strong>82%</strong>
							</div>
							<div class="dashboard-lux-progress">
								<div class="dashboard-lux-progress-bar" style="width: 82%;"></div>
							</div>
							<a href="#" class="dashboard-lux-inline-link">Finaliser mon profil</a>
						</div>
					</section>

					<section class="dashboard-lux-stats">
						<div class="dashboard-lux-stat-card">
							<span class="dashboard-lux-stat-label">Messages</span>
							<h3>12</h3>
							<p>Conversations actives actuellement disponibles.</p>
						</div>

						<div class="dashboard-lux-stat-card">
							<span class="dashboard-lux-stat-label">Demandes</span>
							<h3>05</h3>
							<p>Demandes et projets en cours de traitement.</p>
						</div>

						<div class="dashboard-lux-stat-card">
							<span class="dashboard-lux-stat-label">Projets validés</span>
							<h3>08</h3>
							<p>Dossiers confirmés et finalisés avec succès.</p>
						</div>

						<div class="dashboard-lux-stat-card">
							<span class="dashboard-lux-stat-label">Avis reçus</span>
							<h3>14</h3>
							<p>Évaluations déposées sur votre activité.</p>
						</div>
					</section>

					<div class="row g-4">
						<div class="col-lg-7">
							<section class="dashboard-lux-panel">
								<div class="dashboard-lux-panel-head">
									<div>
										<span class="dashboard-lux-kicker">Activité récente</span>
										<h3>Derniers échanges</h3>
									</div>
									<a href="#" class="dashboard-lux-panel-link">Voir tout</a>
								</div>

								<div class="dashboard-lux-panel-body">
									<a href="#" class="dashboard-lux-message-card">
										<div class="dashboard-lux-message-avatar">
											<img src="https://placehold.co/58x58" alt="Utilisateur">
										</div>
										<div class="dashboard-lux-message-content">
											<div class="dashboard-lux-message-head">
												<h4>Marie Laurent</h4>
												<span>12 mars 2026</span>
											</div>
											<p>Bonjour, nous avons bien reçu votre demande et revenons vers vous avec une proposition détaillée dans les meilleurs délais.</p>
										</div>
									</a>

									<a href="#" class="dashboard-lux-message-card">
										<div class="dashboard-lux-message-avatar">
											<img src="https://placehold.co/58x58" alt="Utilisateur">
										</div>
										<div class="dashboard-lux-message-content">
											<div class="dashboard-lux-message-head">
												<h4>Thomas Bernard</h4>
												<span>10 mars 2026</span>
											</div>
											<p>Merci pour votre retour. Votre dossier est bien pris en compte et nous restons disponibles pour tout complément.</p>
										</div>
									</a>

									<a href="#" class="dashboard-lux-message-card">
										<div class="dashboard-lux-message-avatar">
											<img src="https://placehold.co/58x58" alt="Utilisateur">
										</div>
										<div class="dashboard-lux-message-content">
											<div class="dashboard-lux-message-head">
												<h4>Sophie Martin</h4>
												<span>08 mars 2026</span>
											</div>
											<p>Votre projet est en cours d’étude. Une nouvelle mise à jour sera disponible très prochainement depuis votre espace personnel.</p>
										</div>
									</a>
								</div>
							</section>
						</div>

						<div class="col-lg-5">
							<section class="dashboard-lux-panel">
								<div class="dashboard-lux-panel-head">
									<div>
										<span class="dashboard-lux-kicker">Accès rapide</span>
										<h3>Actions principales</h3>
									</div>
								</div>

								<div class="dashboard-lux-panel-body">
									<div class="dashboard-lux-action-list">
										<a href="#" class="dashboard-lux-action-card">
											<div>
												<h4>Consulter la messagerie</h4>
												<p>Retrouver toutes vos conversations et réponses récentes.</p>
											</div>
											<span>→</span>
										</a>

										<a href="#" class="dashboard-lux-action-card">
											<div>
												<h4>Suivre mes demandes</h4>
												<p>Accéder à l’évolution de vos dossiers et projets en cours.</p>
											</div>
											<span>→</span>
										</a>

										<a href="#" class="dashboard-lux-action-card">
											<div>
												<h4>Modifier mon profil</h4>
												<p>Mettre à jour vos informations personnelles et votre présentation.</p>
											</div>
											<span>→</span>
										</a>

										<a href="#" class="dashboard-lux-action-card">
											<div>
												<h4>Gérer les paramètres</h4>
												<p>Configurer vos préférences et sécuriser votre compte.</p>
											</div>
											<span>→</span>
										</a>
									</div>
								</div>
							</section>
						</div>
					</div>

					<section class="dashboard-lux-panel">
						<div class="dashboard-lux-panel-head">
							<div>
								<span class="dashboard-lux-kicker">Suivi</span>
								<h3>Mes demandes récentes</h3>
							</div>
							<a href="#" class="dashboard-lux-panel-link">Voir tout</a>
						</div>

						<div class="dashboard-lux-panel-body dashboard-lux-table-wrap">
							<div class="table-responsive">
								<table class="table dashboard-lux-table mb-0">
									<thead>
										<tr>
											<th>Projet</th>
											<th>Catégorie</th>
											<th>Statut</th>
											<th>Date</th>
											<th class="text-end">Détail</th>
										</tr>
									</thead>
									<tbody>
										<tr>
											<td>Rénovation salle de bain</td>
											<td>Rénovation</td>
											<td><span class="dashboard-lux-badge dashboard-lux-badge-pending">En attente</span></td>
											<td>11/03/2026</td>
											<td class="text-end"><a href="#" class="dashboard-lux-table-link">Voir</a></td>
										</tr>
										<tr>
											<td>Peinture intérieure</td>
											<td>Travaux</td>
											<td><span class="dashboard-lux-badge dashboard-lux-badge-progress">En cours</span></td>
											<td>09/03/2026</td>
											<td class="text-end"><a href="#" class="dashboard-lux-table-link">Voir</a></td>
										</tr>
										<tr>
											<td>Pose de carrelage</td>
											<td>Aménagement</td>
											<td><span class="dashboard-lux-badge dashboard-lux-badge-valid">Validé</span></td>
											<td>05/03/2026</td>
											<td class="text-end"><a href="#" class="dashboard-lux-table-link">Voir</a></td>
										</tr>
										<tr>
											<td>Installation électrique</td>
											<td>Électricité</td>
											<td><span class="dashboard-lux-badge dashboard-lux-badge-cancel">Annulé</span></td>
											<td>28/02/2026</td>
											<td class="text-end"><a href="#" class="dashboard-lux-table-link">Voir</a></td>
										</tr>
									</tbody>
								</table>
							</div>
						</div>
					</section>

				</div>
			</div>

		</div>
	</div>
</section>

<style>
:root {
	--tm-primary: #A57A5A;
	--tm-primary-dark: #8D6548;
	--tm-primary-soft: #C7A58A;
	--tm-primary-pale: #E8DDD3;
	--tm-cream: #F7F3EE;
	--tm-ivory: #FCFAF7;
	--tm-border: #E8DED5;
	--tm-text: #2E241E;
	--tm-text-soft: #7A6A5D;
	--tm-white: #FFFFFF;
	--tm-shadow: 0 18px 45px rgba(77, 55, 39, 0.08);
}

.dashboard-lux-page {
	background: linear-gradient(180deg, var(--tm-ivory) 0%, #F6F0EA 100%);
	min-height: 100vh;
	padding: 32px 0 60px;
}

.dashboard-lux-banner {
	padding: 46px 0 28px;
	background:
		linear-gradient(135deg, rgba(165, 122, 90, 0.08), rgba(255,255,255,0.82)),
		var(--tm-white);
	border-bottom: 1px solid var(--tm-border);
}

.dashboard-lux-banner-content {
	display: flex;
	align-items: flex-end;
	justify-content: space-between;
	gap: 24px;
}

.dashboard-lux-kicker {
	display: inline-block;
	font-size: 12px;
	font-weight: 700;
	text-transform: uppercase;
	letter-spacing: 0.08em;
	color: var(--tm-primary);
	margin-bottom: 12px;
}

.dashboard-lux-banner-text h1 {
	font-size: 42px;
	line-height: 1.08;
	font-weight: 800;
	color: var(--tm-text);
	margin-bottom: 14px;
}

.dashboard-lux-banner-text p {
	max-width: 760px;
	font-size: 16px;
	line-height: 1.8;
	color: var(--tm-text-soft);
	margin: 0;
}

.dashboard-lux-banner-actions {
	display: flex;
	gap: 12px;
	flex-wrap: wrap;
}

.dashboard-lux-btn {
	display: inline-flex;
	align-items: center;
	justify-content: center;
	min-height: 50px;
	padding: 0 22px;
	border-radius: 14px;
	font-size: 14px;
	font-weight: 700;
	text-decoration: none;
	transition: all 0.25s ease;
	border: 1px solid transparent;
}

.dashboard-lux-btn-primary {
	background: var(--tm-primary);
	color: var(--tm-white);
	box-shadow: 0 12px 28px rgba(165, 122, 90, 0.22);
}

.dashboard-lux-btn-primary:hover {
	background: var(--tm-primary-dark);
	color: var(--tm-white);
	transform: translateY(-1px);
}

.dashboard-lux-btn-outline {
	background: rgba(255,255,255,0.86);
	color: var(--tm-text);
	border-color: var(--tm-border);
}

.dashboard-lux-btn-outline:hover {
	background: var(--tm-cream);
	color: var(--tm-text);
	border-color: #D8C8BB;
}

.dashboard-lux-sidebar,
.dashboard-lux-main {
	display: flex;
	flex-direction: column;
	gap: 22px;
}

.dashboard-lux-profile-card,
.dashboard-lux-nav,
.dashboard-lux-help-card,
.dashboard-lux-intro-card,
.dashboard-lux-stat-card,
.dashboard-lux-panel {
	background: rgba(255,255,255,0.88);
	backdrop-filter: blur(12px);
	border: 1px solid var(--tm-border);
	border-radius: 28px;
	box-shadow: var(--tm-shadow);
}

.dashboard-lux-profile-card {
	overflow: hidden;
}

.dashboard-lux-profile-cover {
	height: 110px;
	background: linear-gradient(135deg, var(--tm-primary-dark), var(--tm-primary), #C9A88E);
}

.dashboard-lux-profile-content {
	position: relative;
	padding: 0 24px 26px;
	text-align: center;
}

.dashboard-lux-profile-avatar {
	width: 110px;
	height: 110px;
	border-radius: 50%;
	overflow: hidden;
	border: 6px solid var(--tm-white);
	margin: -55px auto 16px;
	box-shadow: 0 14px 30px rgba(77, 55, 39, 0.14);
	background: var(--tm-white);
}

.dashboard-lux-profile-avatar img {
	width: 100%;
	height: 100%;
	object-fit: cover;
	display: block;
}

.dashboard-lux-profile-content h3 {
	font-size: 24px;
	font-weight: 800;
	color: var(--tm-text);
	margin-bottom: 6px;
}

.dashboard-lux-profile-subtitle {
	font-size: 14px;
	color: var(--tm-text-soft);
	margin-bottom: 18px;
}

.dashboard-lux-profile-details {
	padding-top: 18px;
	border-top: 1px solid var(--tm-border);
	display: flex;
	flex-direction: column;
	gap: 12px;
}

.dashboard-lux-profile-line {
	display: flex;
	justify-content: space-between;
	align-items: center;
	gap: 12px;
	font-size: 14px;
	color: var(--tm-text);
}

.dashboard-lux-profile-line span {
	color: var(--tm-text-soft);
}

.dashboard-lux-nav {
	padding: 14px;
}

.dashboard-lux-nav-item {
	display: flex;
	align-items: center;
	min-height: 54px;
	padding: 0 18px;
	border-radius: 16px;
	text-decoration: none;
	font-size: 15px;
	font-weight: 700;
	color: var(--tm-text);
	transition: all 0.22s ease;
}

.dashboard-lux-nav-item:hover {
	background: #F8F2EC;
	color: var(--tm-primary-dark);
}

.dashboard-lux-nav-item.active {
	background: linear-gradient(135deg, var(--tm-primary), var(--tm-primary-dark));
	color: var(--tm-white);
	box-shadow: 0 12px 28px rgba(165, 122, 90, 0.22);
}

.dashboard-lux-help-card {
	padding: 24px;
}

.dashboard-lux-help-card h4 {
	font-size: 22px;
	font-weight: 800;
	color: var(--tm-text);
	margin-bottom: 10px;
}

.dashboard-lux-help-card p {
	font-size: 14px;
	line-height: 1.8;
	color: var(--tm-text-soft);
	margin-bottom: 18px;
}

.dashboard-lux-intro-card {
	padding: 28px;
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 24px;
	background:
		linear-gradient(135deg, rgba(165,122,90,0.06), rgba(255,255,255,0.94)),
		var(--tm-white);
}

.dashboard-lux-intro-text h2 {
	font-size: 32px;
	font-weight: 800;
	line-height: 1.2;
	color: var(--tm-text);
	margin-bottom: 12px;
}

.dashboard-lux-intro-text p {
	max-width: 720px;
	font-size: 15px;
	line-height: 1.9;
	color: var(--tm-text-soft);
	margin: 0;
}

.dashboard-lux-completion-card {
	min-width: 290px;
	padding: 22px;
	border-radius: 22px;
	background: rgba(255,255,255,0.72);
	border: 1px solid var(--tm-border);
}

.dashboard-lux-completion-top {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 10px;
	margin-bottom: 12px;
	font-size: 14px;
	font-weight: 700;
	color: var(--tm-text);
}

.dashboard-lux-progress {
	height: 10px;
	border-radius: 999px;
	background: #EEE4DB;
	overflow: hidden;
}

.dashboard-lux-progress-bar {
	height: 100%;
	border-radius: 999px;
	background: linear-gradient(90deg, var(--tm-primary), var(--tm-primary-dark));
}

.dashboard-lux-inline-link {
	display: inline-block;
	margin-top: 12px;
	font-size: 14px;
	font-weight: 700;
	color: var(--tm-primary-dark);
	text-decoration: none;
}

.dashboard-lux-inline-link:hover {
	text-decoration: underline;
}

.dashboard-lux-stats {
	display: grid;
	grid-template-columns: repeat(4, 1fr);
	gap: 18px;
}

.dashboard-lux-stat-card {
	padding: 24px;
	background:
		linear-gradient(180deg, rgba(255,255,255,0.98), rgba(247,243,238,0.9));
}

.dashboard-lux-stat-label {
	display: inline-block;
	font-size: 13px;
	font-weight: 700;
	letter-spacing: 0.02em;
	color: var(--tm-primary-dark);
	margin-bottom: 16px;
}

.dashboard-lux-stat-card h3 {
	font-size: 38px;
	line-height: 1;
	font-weight: 800;
	color: var(--tm-text);
	margin-bottom: 10px;
}

.dashboard-lux-stat-card p {
	font-size: 14px;
	line-height: 1.8;
	color: var(--tm-text-soft);
	margin: 0;
}

.dashboard-lux-panel-head {
	display: flex;
	align-items: flex-start;
	justify-content: space-between;
	gap: 16px;
	padding: 24px 24px 18px;
	border-bottom: 1px solid var(--tm-border);
}

.dashboard-lux-panel-head h3 {
	font-size: 26px;
	font-weight: 800;
	color: var(--tm-text);
	margin: 0;
}

.dashboard-lux-panel-link {
	font-size: 14px;
	font-weight: 700;
	color: var(--tm-primary-dark);
	text-decoration: none;
}

.dashboard-lux-panel-link:hover {
	text-decoration: underline;
}

.dashboard-lux-panel-body {
	padding: 20px 24px 24px;
}

.dashboard-lux-message-card {
	display: flex;
	align-items: flex-start;
	gap: 16px;
	padding: 16px;
	border-radius: 20px;
	border: 1px solid var(--tm-border);
	background: linear-gradient(180deg, #FFFEFD, #FAF6F2);
	text-decoration: none;
	transition: all 0.22s ease;
	margin-bottom: 14px;
}

.dashboard-lux-message-card:last-child {
	margin-bottom: 0;
}

.dashboard-lux-message-card:hover {
	border-color: #D5C1B0;
	box-shadow: 0 14px 32px rgba(165, 122, 90, 0.12);
	transform: translateY(-1px);
}

.dashboard-lux-message-avatar {
	width: 58px;
	height: 58px;
	border-radius: 50%;
	overflow: hidden;
	flex-shrink: 0;
	background: #EFE4DA;
}

.dashboard-lux-message-avatar img {
	width: 100%;
	height: 100%;
	object-fit: cover;
	display: block;
}

.dashboard-lux-message-content {
	flex: 1;
	min-width: 0;
}

.dashboard-lux-message-head {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 12px;
	margin-bottom: 8px;
}

.dashboard-lux-message-head h4 {
	font-size: 16px;
	font-weight: 800;
	color: var(--tm-text);
	margin: 0;
}

.dashboard-lux-message-head span {
	font-size: 12px;
	font-weight: 700;
	color: #9B8777;
	white-space: nowrap;
}

.dashboard-lux-message-content p {
	margin: 0;
	font-size: 14px;
	line-height: 1.8;
	color: var(--tm-text-soft);
}

.dashboard-lux-action-list {
	display: flex;
	flex-direction: column;
	gap: 14px;
}

.dashboard-lux-action-card {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 16px;
	padding: 18px;
	border-radius: 20px;
	border: 1px solid var(--tm-border);
	background: linear-gradient(180deg, #FFFEFD, #FAF6F2);
