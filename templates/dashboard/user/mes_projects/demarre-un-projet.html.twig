{% extends 'user.html.twig' %}

{% block title %}Démarrer un projet{% endblock %}

{% block body %}
    <main class="tm-new-project-page">
        <section class="tm-new-project-header">
            <div>
                <span class="tm-new-project-eyebrow">Nouveau projet</span>
                <h1>Démarrer un projet</h1>
                <p>Décrivez vos travaux, ajoutez quelques photos.</p>
            </div>
            <div class="tm-new-project-stats">
                <div><span>Temps moyen</span><strong>3 min</strong></div>
                <div><span>Devis sous</span><strong>48 h</strong></div>
                <div><span>Pertinence</span><strong>94 %</strong></div>
            </div>
        </section>

        {{ form_start(form, { attr: { 'data-turbo': 'false' } }) }}

        {{ form_errors(form) }}

        <section class="tm-new-project-layout">
            <div class="tm-new-project-form">

                <div class="tm-new-project-card" data-controller="metier">

                    <div class="tm-new-project-card-title">
                        <span>1</span>
                        <h2>Type de travaux</h2>
                    </div>

                    <div class="tm-choice-grid" style="grid-template-columns: repeat(3, 1fr)!important;">

                        {% for choice in form.metierPrincipal %}

                            <label class="{{ choice.vars.checked ? 'active' : '' }}">

                                {{ form_widget(choice, {
                                    attr: {
                                        'data-action': 'change->metier#toggleAutre',
                                        'data-metier-target': 'radio'
                                    }
                                }) }}

                                <span>{{ choice.vars.label }}</span>

                            </label>

                        {% endfor %}

                        {# Bouton Autre manuel #}
                        <label data-metier-target="autreButton">
                            <input
                                type="radio"
                                name="fake_autre"
                                data-action="change->metier#toggleAutreSelect"
                            >

                            <span>Autre</span>
                        </label>

                    </div>

                    <div class="mt-16 d-none" data-metier-target="autreWrapper">

                        {{ form_widget(form.autreMetier, {
                            attr: {
                                class: 'form-select'
                            }
                        }) }}

                    </div>

                </div>

                <div class="tm-new-project-card">
                    <div class="tm-new-project-card-title">
                        <span>2</span>
                        <h2>Décrivez votre projet</h2>
                    </div>
                    <div class="tm-form-group">
                        <label>Titre</label>
                        {{ form_widget(form.titre) }}
                    </div>
                    <div class="tm-form-group">
                        <label>Description détaillée</label>
                        {{ form_widget(form.description) }}
                    </div>
                    <div class="tm-form-row">
                        <div class="tm-form-group">
                            <label>Surface</label>
                            {{ form_widget(form.surface) }}
                        </div>
                        <div class="tm-form-group">
                            <label>Quand commencer ?</label>
                            <div class="tm-small-choices">
                                {% for child in form.debutChantier %}
                                    <label class="{{ child.vars.checked ? 'active' : '' }}">
                                        {{ form_widget(child) }}
                                        <span>{{ child.vars.label }}</span>
                                    </label>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                </div>

                <div class="tm-new-project-card">
                    <div class="tm-new-project-card-title">
                        <span>3</span>
                        <h2>Photos & documents</h2>
                    </div>

                    <div id="photos-wrapper" style="display:none;">
                        {{ form_widget(form.photos) }}
                    </div>

                    <div class="tm-upload-grid" id="tm-upload-grid">
                        <label class="tm-upload-add">
                            <input type="file" id="tm-file-trigger" hidden multiple accept="image/*">
                            <i class="fa-solid fa-upload"></i>
                            <span>Ajouter</span>
                        </label>
                    </div>
                </div>

            </div>

            <aside class="tm-new-project-sidebar">
                <div class="tm-budget-card">
                    <h3>Budget envisagé</h3>
                    <strong class="tm-budget-display">28 000 €</strong>
                    <span>Estimation indicative TTC</span>
                    <div class="tm-budget-range">
                        <div>
                            <small>500 €</small>
                            <small>100 000 €</small>
                        </div>
                        {{ form_widget(form.budget) }}
                    </div>
                    <div class="tm-budget-note">
                        <strong>À titre indicatif</strong>
                        <p>Pour une cuisine 12 m² avec îlot, comptez généralement 22 000 € à 35 000 €.</p>
                    </div>
                </div>

                <div class="tm-next-card">
                    <h3>Ce qui se passe ensuite</h3>
                    <ol>
                        <li>Nous identifions 3-5 artisans qualifiés</li>
                        <li>Ils étudient votre projet sous 24-48h</li>
                        <li>Vous recevez et comparez les devis</li>
                        <li>Vous choisissez en toute confiance</li>
                    </ol>
                </div>

                <button class="tm-submit-project" type="submit">
                    Publier mon projet
                </button>
            </aside>

        </section>
        {{ form_end(form) }}
    </main>

    <style>
        .tm-upload-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
        }

        .tm-upload-image {
            position: relative;
            aspect-ratio: 1;
            border-radius: 8px;
            background-size: cover;
            background-position: center;
            background-color: #e9ecef;
        }

        .tm-upload-image button {
            position: absolute;
            top: 4px;
            right: 4px;
            width: 22px;
            height: 22px;
            border: none;
            border-radius: 50%;
            background: rgba(0, 0, 0, 0.55);
            color: #fff;
            font-size: 14px;
            line-height: 1;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0;
        }

        .tm-upload-add {
            aspect-ratio: 1;
            border: 2px dashed #003EC7;
            border-radius: 8px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 6px;
            cursor: pointer;
            color: #003EC7;
            font-size: 13px;
            transition: background .2s;
        }

        .tm-upload-add:hover { background: #eef2ff; }
        .tm-upload-add i { font-size: 20px; }
        .tm-metier-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 10px;
        }

        .tm-metier-choice {
            margin: 0;
        }

        .tm-metier-input {
            display: none;
        }

        .tm-metier-label {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 50px;
            border: 1px solid #ddd;
            border-radius: 9px;
            background: #fff;
            font-size: 16px;
            cursor: pointer;
        }

        .tm-metier-input:checked + .tm-metier-label {
            border-color: #0057ff;
            background: #f2f6ff;
            color: #0057ff;
        }
    </style>
{% endblock %}

{% block javascripts %}
    {{ parent() }}

    <script>
        document.addEventListener('DOMContentLoaded', () => {

            // ----------------------------------------------------------------
            // Upload photos
            // ----------------------------------------------------------------
            const trigger  = document.getElementById('tm-file-trigger');
            const grid     = document.getElementById('tm-upload-grid');
            const addLabel = grid.querySelector('.tm-upload-add');
            const realInput = document.querySelector('#photos-wrapper input[type="file"]');

            if (!trigger || !grid) {
                console.error('[upload] Éléments DOM manquants.');
                return;
            }

            let dt = new DataTransfer();

            trigger.addEventListener('change', (e) => {
                Array.from(e.target.files).forEach(addFile);
                trigger.value = '';
            });

            function addFile(file) {
                if (!file.type.startsWith('image/')) return;

                // 1. Miniature en premier — indépendante de realInput
                const reader = new FileReader();
                reader.onload = (ev) => {
                    const div = document.createElement('div');
                    div.className = 'tm-upload-image';
                    div.style.backgroundImage = `url('${ev.target.result}')`;
                    div.dataset.fileName = file.name;

                    const btn = document.createElement('button');
                    btn.type = 'button';
                    btn.textContent = '×';
                    btn.addEventListener('click', () => removeFile(file.name, div));

                    div.appendChild(btn);
                    grid.insertBefore(div, addLabel);
                };
                reader.readAsDataURL(file);

                // 2. Sync vers l'input Symfony
                dt.items.add(file);
                syncRealInput();
            }

            function removeFile(name, div) {
                const newDt = new DataTransfer();
                Array.from(dt.files)
                    .filter(f => f.name !== name)
                    .forEach(f => newDt.items.add(f));
                dt = newDt;
                syncRealInput();
                div.remove();
            }

            function syncRealInput() {
                if (!realInput) {
                    console.warn('[upload] realInput introuvable — les fichiers ne seront pas soumis.');
                    return;
                }
                realInput.files = dt.files;
            }

            // ----------------------------------------------------------------
            // Budget range dynamique
            // ----------------------------------------------------------------
            const budgetInput   = document.querySelector('input[type="range"]');
            const budgetDisplay = document.querySelector('.tm-budget-display');

            const formatBudget = (val) => parseInt(val).toLocaleString('fr-FR') + ' €';

            if (budgetInput && budgetDisplay) {
                // Affichage initial
                budgetDisplay.textContent = formatBudget(budgetInput.value);

                // Mise à jour en temps réel
                budgetInput.addEventListener('input', (e) => {
                    budgetDisplay.textContent = formatBudget(e.target.value);
                });
            }

            // ----------------------------------------------------------------
            // Choix de date (radio)
            // ----------------------------------------------------------------
            document.querySelectorAll('.tm-small-choices input[type="radio"]').forEach((radio) => {
                radio.addEventListener('change', () => {
                    radio.closest('.tm-small-choices')
                        .querySelectorAll(':scope > label')
                        .forEach(l => l.classList.remove('active'));
                    radio.closest('label').classList.add('active');
                });
            });

        });
    </script>
{% endblock %}
