{% extends 'artisan.html.twig' %}

{% block title %}Profil artisan{% endblock %}

{% block body %}
    <main class="tm-artisan-profile-page">
        <div class="container tm-artisan-profile-container">

            <section class="tm-artisan-profile-card">

                <div
                    class="tm-artisan-profile-hero"
                    style="background-image: url('https://www.figma.com/api/mcp/asset/02e48672-c4ea-457b-83fb-62aa67ce3b37');"
                >
                    <div class="tm-artisan-profile-overlay"></div>

                    <div class="tm-artisan-profile-hero-top">
                        <a href="#" class="tm-profile-btn-light text-decoration-none">Changer la couverture</a>
                    </div>

                    <div class="tm-artisan-profile-hero-bottom">
                        <div class="tm-artisan-profile-badges">
                            <span class="tm-artisan-master-badge">Maître artisan</span>

                            <div class="tm-artisan-rating">
                                <span class="tm-artisan-rating-star">★</span>
                                <strong>4.9</strong>
                                <small>(150+ avis)</small>
                            </div>
                        </div>

                        <h1>Atelier du Béton</h1>

                        <div class="tm-artisan-profile-meta">
                            <span>📍 Bordeaux, France</span>
                            <span>📅 Inscrit en 2012</span>
                            <span class="is-green">🛡 Assurance Professionnelle Certifiée</span>
                        </div>
                    </div>
                </div>

                <div class="tm-artisan-profile-tags">
                    <span>Maître artisan</span>
                    <span>Qualibat 2143</span>
                    <span>RGE</span>
                    <span>Décennale</span>
