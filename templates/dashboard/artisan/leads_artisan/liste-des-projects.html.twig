{% extends 'artisan.html.twig' %}

{% block title %}Mes leads{% endblock %}

{% block body %}
    <main class="tm-artisan-leads-page">
        <div class="container tm-artisan-leads-container">

            <section class="tm-leads-hero">
                <div class="tm-leads-eyebrow">Espace artisan</div>
                <h1 class="tm-leads-title">Mes leads</h1>
                <p class="tm-leads-subtitle">
                    12 demandes correspondent à votre profil · taux de match moyen 78%
                </p>
            </section>

            <section class="tm-leads-filters">
                <div class="row g-3 align-items-center">
                    <div class="col-12 col-xl">
                        <div class="tm-filter-search">
                            <input type="text" class="form-control" placeholder="Rechercher">
                        </div>
                    </div>

                    <div class="col-6 col-md-3 col-xl">
                        <select class="form-select">
                            <option>Tous types</option>
                        </select>
                    </div>

                    <div class="col-6 col-md-3 col-xl">
                        <select class="form-select">
                            <option>Tous budget</option>
                        </select>
                    </div>

                    <div class="col-6 col-md-3 col-xl">
                        <select class="form-select">
                            <option>≤ 30 km</option>
                        </select>
                    </div>

                    <div class="col-6 col-md-3 col-xl">
                        <select class="form-select">
                            <option>Match ≥ 70%</option>
                        </select>
                    </div>

                    <div class="col-12 col-xl-auto">
                        <button class="tm-filter-btn">Appliquer le filtre</button>
                    </div>
                </div>
            </section>

            <section class="tm-leads-list">

                <article class="tm-lead-card">
                    <div class="tm-lead-card-top">
                        <div class="tm-lead-main">
                            <div class="tm-lead-avatar is-blue">SO</div>

                            <div class="tm-lead-content">
                                <div class="tm-lead-head">
                                    <h2>Sophie Bernard</h2>
                                    <span class="tm-tag is-red">Nouveau</span>
                                    <span class="tm-tag is-orange">Urgent</span>
                                    <small>· Il y a 12 min</small>
                                </div>

                                <div class="tm-lead-project">Rénovation cuisine 14m² · Il y a 12 min</div>
                                <p class="tm-lead-description">
                                    Cuisine ouverte sur séjour, démolition cloison non porteuse, plomberie à reprendre.
                                </p>
                            </div>
                        </div>

                        <div class="tm-lead-side">
                            <div class="tm-match-box">
                                <span>Match</span>
                                <div class="tm-match-line">
                                    <div class="tm-match-line-bar is-green" style="width:96%;"></div>
                                </div>
                                <strong class="is-green">96%</strong>
                            </div>

                            <div class="tm-lead-actions">
                                <a href="#" class="tm-btn-light">Passer</a>
                                <a href="#" class="tm-btn-light">Sauver</a>
                                <a href="#" class="tm-btn-primary">Etudier</a>
                            </div>
                        </div>
                    </div>

                    <div class="tm-lead-meta">
                        <span>Paris 16ᵉ · 8 km</span>
                        <span>25 000 - 35 000 €</span>
                        <span>Démarrage sous 1 mois</span>
                        <span>6 photos</span>
                    </div>
                </article>

                <article class="tm-lead-card">
                    <div class="tm-lead-card-top">
                        <div class="tm-lead-main">
                            <div class="tm-lead-avatar is-pink">MA</div>

                            <div class="tm-lead-content">
                                <div class="tm-lead-head">
                                    <h2>Marc Dupont</h2>
                                    <span class="tm-tag is-red">Nouveau</span>
                                    <span class="tm-tag is-blue">Normale</span>
                                    <small>· Il y a 1 h</small>
                                </div>

                                <div class="tm-lead-project">Salle de bain complète</div>
