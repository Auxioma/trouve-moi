            </section>

            <nav class="tm-leads-pagination">
                <a href="#">‹</a>
                <a href="#" class="active">1</a>
                <a href="#">2</a>
                <a href="#">3</a>
                <span>...</span>
                <a href="#">10</a>
                <a href="#">›</a>
            </nav>

            <section class="tm-leads-footer-card">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                    <div class="tm-leads-footer-brand">
                        <strong>TrouveMoi</strong>
                        <span>|</span>
