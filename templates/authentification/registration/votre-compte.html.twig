{% extends 'user.html.twig' %}

{% block title %}Inscription | Créer votre compte{% endblock %}

{% block body %}
    <main class="tm-signup-account-page">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-12 col-xl-10">
                    <section class="tm-signup-account-wrap">

                        <div class="tm-signup-account-brand text-center">
                            <a href="{{ path('app_home') }}" class="tm-signup-account-logo-link text-decoration-none">
                                <img
                                    src="{{ asset('image/logo/logo.png') }}"
                                    alt="TrouveMoi"
                                    class="tm-signup-account-logo img-fluid"
                                >
                            </a>
                        </div>

                        <div class="tm-signup-account-step text-center">
                            <div class="tm-signup-account-step-title">
                                Vos coordonnées
                            </div>

                            <div class="tm-signup-account-progress d-flex align-items-center justify-content-center">
                                <span class="tm-signup-account-progress-item is-active"></span>
                                <span class="tm-signup-account-progress-item is-active"></span>
                                <span class="tm-signup-account-progress-item"></span>
                            </div>
                        </div>

                        <div class="tm-signup-account-card">

                            <div class="tm-signup-account-head">
                                <div class="tm-signup-account-eyebrow">
                                    Étape 2 sur 4
                                </div>

                                <h1 class="tm-signup-account-title">
                                    Créez votre compte
                                </h1>

                                <p class="tm-signup-account-subtitle">
                                    On vous mettra en relation avec des artisans dès que votre projet sera publié.
                                </p>
                            </div>

                            {{ form_start(form, {
                                attr: {
                                    class: 'tm-signup-account-form',
                                    novalidate: 'novalidate',
                                    'data-turbo': 'false'
                                }
                            }) }}

                            <div class="row g-4">

                                <div class="col-md-6">
                                    <label class="tm-signup-account-label">
                                        Prénom*
                                    </label>

                                    {{ form_widget(form.firstName, {
                                        attr: {
                                            class: 'form-control tm-signup-account-input' ~ (form.firstName.vars.errors|length ? ' is-invalid' : ''),
                                            placeholder: 'Votre prénom'
                                        }
                                    }) }}

                                    <p class="text-danger">
                                        {{ form.firstName.vars.errors|first.message ?? '' }}
                                    </p>
                                </div>

                                <div class="col-md-6">
                                    <label class="tm-signup-account-label">
                                        Nom*
                                    </label>

                                    {{ form_widget(form.lastName, {
                                        attr: {
                                            class: 'form-control tm-signup-account-input' ~ (form.lastName.vars.errors|length ? ' is-invalid' : ''),
                                            placeholder: 'Votre nom'
                                        }
                                    }) }}

                                    <p class="text-danger">
                                        {{ form.lastName.vars.errors|first.message ?? '' }}
                                    </p>
                                </div>

                                <div class="col-md-6">
                                    <label class="tm-signup-account-label">
                                        Email*
                                    </label>

                                    {{ form_widget(form.email, {
                                        attr: {
                                            class: 'form-control tm-signup-account-input' ~ (form.email.vars.errors|length ? ' is-invalid' : ''),
                                            placeholder: 'Votre email'
                                        }
                                    }) }}

                                    <p class="text-danger">
                                        {{ form.email.vars.errors|first.message ?? '' }}
                                    </p>
                                </div>

                                <div class="col-md-6">
                                    <label class="tm-signup-account-label">
                                        Téléphone*
                                    </label>

                                    {{ form_widget(form.phoneNumber, {
                                        attr: {
                                            class: 'form-control tm-signup-account-input' ~ (form.phoneNumber.vars.errors|length ? ' is-invalid' : ''),
                                            placeholder: '+33 6 00 00 00 00'
                                        }
                                    }) }}

                                    <p class="text-danger">
                                        {{ form.phoneNumber.vars.errors|first.message ?? '' }}
                                    </p>
                                </div>

                                <div class="col-12">
                                    <label class="tm-signup-account-label">
                                        Mot de passe*
                                    </label>

                                    {{ form_widget(form.plainPassword, {
                                        attr: {
                                            class: 'form-control tm-signup-account-input' ~ (form.plainPassword.vars.errors|length ? ' is-invalid' : ''),
                                            placeholder: 'Votre mot de passe'
                                        }
                                    }) }}

                                    <p class="text-danger">
                                        {{ form.plainPassword.vars.errors|first.message ?? '' }}
                                    </p>

                                    <div class="tm-signup-account-help">
                                        8 caractères min, une majuscule et un chiffre.
                                    </div>
                                </div>

                                <div class="col-12">

                                    <label class="tm-signup-account-consent d-flex align-items-start gap-2">

                                        {{ form_widget(form.agreeTerms, {
                                            attr: {
                                                class: form.agreeTerms.vars.errors|length ? 'is-invalid' : '',
                                            }
                                        }) }}

                                        <span>
                                            J'accepte les
                                            <a href="#" class="text-decoration-none">
                                                conditions d'utilisation
                                            </a>
                                            et la politique de confidentialité de TrouveMoi.
                                        </span>

                                    </label>

                                    <p class="text-danger">
                                        {{ form.agreeTerms.vars.errors|first.message ?? '' }}
                                    </p>

                                </div>

                            </div>

                            <div class="d-flex align-items-center justify-content-between gap-3 flex-wrap tm-signup-account-actions">

                                <a href="#" class="tm-signup-account-btn-back text-decoration-none">
                                    Retour
                                </a>

                                <button type="submit" class="tm-signup-account-btn-next">
                                    Créer mon compte
                                </button>

                            </div>

                            {{ form_end(form) }}

                        </div>

                    </section>
                </div>
            </div>
        </div>
    </main>
{% endblock %}
