{% extends 'user.html.twig' %}

{% block title %}Inscription professionnelle{% endblock %}

{% block body %}
    <main class="tm-signup-pro-page">
        <div class="container">
            <div class="tm-signup-pro-wrap">

                <div class="tm-signup-pro-brand text-center">
                    <img
                        src="{{ asset('image/logo/logo.png') }}"
                        alt="TrouveMoi"
                        class="tm-signup-pro-logo img-fluid"
                    >
                </div>

                <div class="tm-signup-pro-step text-center">
                    <div class="tm-signup-pro-step-title">
                        Inscription artisan
                    </div>

                    <div class="tm-signup-pro-progress d-flex align-items-center justify-content-center">
                        <span class="tm-signup-pro-progress-item is-active"></span>
                        <span class="tm-signup-pro-progress-item is-active"></span>
                        <span class="tm-signup-pro-progress-item"></span>
                    </div>
                </div>

                <section class="tm-signup-pro-card">

                    <div class="tm-signup-pro-head">
                        <div class="tm-signup-pro-eyebrow">
                            Étape 2 sur 3
                        </div>

                        <h1 class="tm-signup-pro-title">
                            Créez votre profil artisan
                        </h1>

                        <p class="tm-signup-pro-subtitle">
                            Présentez votre entreprise, vos compétences et vos réalisations afin d’être visible auprès des particuliers recherchant un artisan de confiance.
                        </p>
                    </div>

                    {{ form_start(form, {
                        attr: {
                            class: 'tm-signup-pro-form',
                            novalidate: 'novalidate',
                            'data-turbo': 'false'
                        }
                    }) }}

                    <div class="row">

                        <div class="col-md-6">
                            <label class="tm-signup-pro-label">
                                Nom de l’entreprise*
                            </label>

                            {{ form_widget(form.compagny, {
                                attr: {
                                    class: 'form-control tm-signup-pro-input' ~ (form.compagny.vars.errors|length ? ' is-invalid' : ''),
                                    placeholder: 'Ex : Bâtiment Dupont',
                                }
                            }) }}

                            <p class="text-danger">
                                {{ form.compagny.vars.errors|first.message ?? '' }}
                            </p>
                        </div>

                        <div class="col-md-6">
                            <label class="tm-signup-pro-label">
                                SIRET*
                            </label>

                            {{ form_widget(form.siret, {
                                attr: {
                                    class: 'form-control tm-signup-pro-input' ~ (form.siret.vars.errors|length ? ' is-invalid' : ''),
                                }
                            }) }}

                            <p class="text-danger">
                                {{ form.siret.vars.errors|first.message ?? '' }}
                            </p>
                        </div>

                        <div class="col-md-6">
                            <label class="tm-signup-pro-label">
                                Nom du dirigeant*
                            </label>

                            {{ form_widget(form.lastName, {
                                attr: {
                                    class: 'form-control tm-signup-pro-input' ~ (form.lastName.vars.errors|length ? ' is-invalid' : ''),
                                }
                            }) }}

                            <p class="text-danger">
                                {{ form.lastName.vars.errors|first.message ?? '' }}
                            </p>
                        </div>

                        <div class="col-md-6">
                            <label class="tm-signup-pro-label">
                                Téléphone*
                            </label>

                            {{ form_widget(form.phoneNumber, {
                                attr: {
                                    class: 'form-control tm-signup-pro-input' ~ (form.phoneNumber.vars.errors|length ? ' is-invalid' : ''),
                                }
                            }) }}

                            <p class="text-danger">
                                {{ form.phoneNumber.vars.errors|first.message ?? '' }}
                            </p>
                        </div>

                        <div class="col-md-6">
                            <label class="tm-signup-pro-label">
                                Email professionnel*
                            </label>

                            {{ form_widget(form.email, {
                                attr: {
                                    class: 'form-control tm-signup-pro-input' ~ (form.email.vars.errors|length ? ' is-invalid' : ''),
                                }
                            }) }}

                            <p class="text-danger">
                                {{ form.email.vars.errors|first.message ?? '' }}
                            </p>
                        </div>

                        <div class="col-md-6">
                            <label class="tm-signup-pro-label">
                                Métier principal*
                            </label>

                            {{ form_widget(form.activity, {
                                attr: {
                                    class: 'form-select tm-signup-pro-select' ~ (form.activity.vars.errors|length ? ' is-invalid' : '')
                                }
                            }) }}

                            <p class="text-danger">
                                {{ form.activity.vars.errors|first.message ?? '' }}
                            </p>
                        </div>

                        <div class="col-md-6">
                            <label class="tm-signup-pro-label">
                                Ville*
                            </label>

                            {{ form_widget(form.city, {
                                attr: {
                                    class: 'tm-signup-pro-input' ~ (form.city.vars.errors|length ? ' is-invalid' : ''),
                                    placeholder: 'Ex : Paris',
                                }
                            }) }}

                            <p class="text-danger">
                                {{ form.city.vars.errors|first.message ?? '' }}
                            </p>
                        </div>

                        <div class="col-md-6">
                            <label class="tm-signup-pro-label">
                                Site web
                            </label>

                            {{ form_widget(form.website, {
                                attr: {
                                    class: 'form-control tm-signup-pro-input' ~ (form.website.vars.errors|length ? ' is-invalid' : ''),
                                }
                            }) }}

                            <p class="text-danger">
                                {{ form.website.vars.errors|first.message ?? '' }}
                            </p>
                        </div>

                        <div class="col-12">
                            <label class="tm-signup-pro-label">
                                Présentation de votre activité*
                            </label>

                            {{ form_widget(form.description, {
                                attr: {
                                    class: 'form-control tm-signup-pro-textarea' ~ (form.description.vars.errors|length ? ' is-invalid' : ''),
                                    minlength: 500,
                                    oninput: '
                                            const count = this.value.length;
                                            const counter = document.getElementById("description-count");
                                            const help = document.getElementById("description-help");
                                            const remaining = document.getElementById("description-remaining");

                                            counter.innerText = count;
                                            remaining.innerText = Math.max(500 - count, 0);

                                            if (count >= 500) {
                                                help.classList.remove("text-danger");
                                                help.classList.add("text-success");
                                            } else {
                                                help.classList.remove("text-success");
                                                help.classList.add("text-danger");
                                            }
        '
                                }
                            }) }}

                            <p class="text-danger">
                                {{ form.description.vars.errors|first.message ?? '' }}
                            </p>

                            <div id="description-help" class="tm-signup-pro-help text-danger">
                                <span id="description-count">0</span>/500 caractères —
                                il reste <span id="description-remaining">500</span> caractères minimum.
                            </div>
                        </div>

                        <div class="col-12">
                            <label class="tm-signup-pro-label">
                                Logo ou photo d’entreprise
                            </label>

                            <div class="tm-signup-pro-upload">

                                <i class="fa-solid fa-cloud-arrow-up"></i>

                                <strong>
                                    Déposez votre logo
                                </strong>

                                <p>
                                    PNG, JPG ou WEBP · max 5MB
                                </p>

                                {{ form_widget(form.imageFile, {
                                    attr: {
                                        accept: 'image/png,image/jpeg,image/webp',
                                        onchange: '
                                                    const file = this.files[0];

                                                    if (file) {
                                                        const reader = new FileReader();

                                                        reader.onload = function(e) {
                                                            const preview = document.getElementById("image-preview");

                                                            preview.src = e.target.result;
                                                            preview.classList.remove("d-none");
                                                        };

                                                        reader.readAsDataURL(file);
                                                    }
                                                '
                                    }
                                }) }}

                                <img
                                    id="image-preview"
                                    class="d-none mt-3 rounded-4 img-fluid"
                                    style="max-width: 200px; max-height: 200px; object-fit: cover;"
                                    alt="Prévisualisation du logo"
                                >

                            </div>

                            <p class="text-danger">
                                {{ form.imageFile.vars.errors|first.message ?? '' }}
                            </p>
                        </div>

                        <div class="col-12">
                            <label class="tm-signup-pro-label">
                                Mot de passe*
                            </label>

                            {{ form_widget(form.plainPassword, {
                                attr: {
                                    class: 'form-control tm-signup-pro-input' ~ (form.plainPassword.vars.errors|length ? ' is-invalid' : ''),
                                }
                            }) }}

                            <p class="text-danger">
                                {{ form.plainPassword.vars.errors|first.message ?? '' }}
                            </p>

                            <div class="tm-signup-pro-help">
                                12 caractères minimum, une majuscule, une minuscule et un chiffre.
                            </div>
                        </div>

                        <div class="col-12">
                            <label class="tm-signup-pro-consent d-flex align-items-start gap-3">

                                {{ form_widget(form.agreeTerms, {
                                    attr: {
                                        class: form.agreeTerms.vars.errors|length ? 'is-invalid' : '',
                                    }
                                }) }}

                                <span>
                                    J’accepte les
                                    <a href="#">conditions d’utilisation</a>
                                    ainsi que la politique de confidentialité de TrouveMoi.
                                </span>
                            </label>

                            <p class="text-danger">
                                {{ form.agreeTerms.vars.errors|first.message ?? '' }}
                            </p>

                        </div>

                    </div>

                    <div class="tm-signup-pro-actions d-flex align-items-center justify-content-between gap-3">
                        <button type="button" class="tm-signup-pro-btn-back">
                            Retour
                        </button>

                        <button type="submit" class="tm-signup-pro-btn-submit">
                            Créer mon profil artisan
                        </button>
                    </div>

                    {{ form_end(form) }}

                </section>

            </div>
        </div>
    </main>
{% endblock %}
