{% extends 'base.html.twig' %}

{% block title %}Register{% endblock %}

{% block body %}
        <section class="hero-section register mb-5 d-flex align-items-start">
            <div class="container px-4 px-lg-5 pt-5 position-relative" style="z-index:2">
                <div class="row">
                    <div class="col-lg-7">
                        <h1 class="hero-title mb-4">Connexion à votre espace artisan</h1>
                        <p class="hero-text mb-0">
                            Accédez à votre tableau de bord pour gérer vos clients
                            et vos demandes.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- CONTENT -->
        <section class="content-section">
            <div class="container">
                <div class="row">
                    <div class="col-12 col-lg-7">
                        <h2 class="section-title mb-3">Connexion à votre espace artisan</h2>
                        <p class="section-text mb-4">
                            Accédez à votre tableau de bord pour gérer vos clients et vos
                            demandes.
                        </p>

                        <div class="custom-card p-4">
                            <div class="mb-3">
                                <label class="d-flex align-items-center gap-2 mb-2 label-title">
                                    <span class="icon-badge">👤</span>
                                    <span>Email</span>
                                </label>
                                <input type="email" class="form-control form-input-lg" placeholder="email@exemple.fr">
                            </div>

                            <div class="soft-separator my-3"></div>

                            <div class="mb-3">
                                <label class="d-flex align-items-center gap-2 mb-2 label-title">
                                    <span class="icon-badge">🔒</span>
                                    <span>Mot de passe</span>
                                </label>
                                <input type="password" class="form-control form-input-lg" value="12345678">
                            </div>

                            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 my-4">
                                <div class="form-check m-0">
                                    <input class="form-check-input" type="checkbox" id="rememberMe">
                                    <label class="form-check-label fw-semibold" for="rememberMe">
                                        Se souvenir de moi
                                    </label>
                                </div>

                                <a href="#" class="text-decoration-none fw-semibold text-dark">Mot de passe oublié ?</a>
                            </div>

                            <div class="d-grid">
                                <button class="btn btn-login py-2">Se connecter</button>
                            </div>

                            <div class="text-center mt-4">
                                <span class="text-dark">Déjà inscrit ? </span>
                                <a href="#" class="text-decoration-none fw-semibold text-dark">Se connecter</a>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-5 pt-lg-5">
                        <div class="custom-card p-4">
                            <h3 class="side-title fs-2 mb-3">Pourquoi se connecter ?</h3>

                            <hr class="my-3">

                            <div class="d-flex flex-column gap-3 mb-4">
                                <div class="d-flex align-items-center gap-3 check-item">
                                    <span class="check-mark">✓</span>
                                    <span>Gérer votre fiche artisan</span>
                                </div>
                                <div class="d-flex align-items-center gap-3 check-item">
                                    <span class="check-mark">✓</span>
                                    <span>Recevoir des demandes clients</span>
                                </div>
                                <div class="d-flex align-items-center gap-3 check-item">
                                    <span class="check-mark">✓</span>
                                    <span>Répondre aux messages</span>
                                </div>
                                <div class="d-flex align-items-center gap-3 check-item">
                                    <span class="check-mark">✓</span>
                                    <span>Suivre votre réputation</span>
                                </div>
                            </div>

                            <div class="mini-illustration">
                                <div class="card-a"></div>
                                <div class="card-b"></div>
                                <div class="screen"></div>
                                <div class="phone"></div>
                                <div class="mail"></div>
                                <div class="badge-up"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-5">
                    <h3 class="section-title fs-1 mb-3">Pas encore inscrit ?</h3>
                    <button class="btn btn-blue-main px-4 py-2">
                        Créer mon profil artisan gratuitement
                    </button>
                </div>
            </div>
        </section>

        <div class="footer-curve"></div>
{% endblock %}
