<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>Inscription</title>

		<style>
			*,
			*::before,
			*::after {
				box-sizing: border-box;
				padding: 0;
				margin: 0;
				font-family: sans-serif;
			}

			body {
				min-height: 100vh;
				background-color: #fff;
			}

			.grid {
				display: grid;
				grid-template-columns: 1fr 1fr;
				min-height: 100vh;
			}

			.order__left {
				order: 1;
				padding: 40px;
			}

			.order__right {
				order: 2;
			}

			.centered {
				display: flex;
				align-items: center;
				justify-content: center;
			}

			.no__overflow {
				display: flex;
				align-items: center;
				overflow: hidden;
			}

			.form {
				max-width: 500px;
				width: 100%;
			}

			.logo {
				margin-bottom: 12px;
			}

			.header-logo {
				max-width: 180px;
				height: auto;
				display: block;
			}

			h4 {
				color: #867992;
				text-align: justify;
				margin-bottom: 30px;
				letter-spacing: 0.2px;
				line-height: 20px;
				font-weight: 500;
			}

			h3 {
				text-align: center;
				padding: 20px 0;
				color: #4F4659;
			}

			input:not([type="checkbox"]):not([type="radio"]):not([type="submit"]):not([type="file"]) {
				width: 100%;
				padding: 12px 16px;
				margin: 16px 0;
				display: block;
				border: 1px solid #c8c3cf;
				border-radius: 4px;
				background-color: #F6F5F7;
				font-size: 16px;
				color: #4F4659;
				outline: none;
				transition: box-shadow 0.25s ease-in-out, background-color 0.25s ease-in-out, border-color 0.25s ease-in-out;
			}

			input[type="email"]:focus,
			input[type="password"]:focus,
			input[type="text"]:focus {
				border-color: #A26ED4;
				background: #FDFCFE;
				box-shadow: 0 0 0 0.25rem #ebd6ff;
			}

			::placeholder {
				color: #A29CA8;
			}

			input[type="checkbox"],
			label {
				cursor: pointer;
				outline-color: #B595D4;
			}

			.remember_me,
			.signup {
				color: #867992;
			}

			.forgot__password {
				color: #551A8B;
				text-align: left;
				outline-color: #B595D4;
				text-decoration: none;
			}

			.forgot__password:active {
				color: #867992;
			}

			.login__button {
				outline-color: #734E96;
				width: 100%;
				border: none;
				background-color: #A26ED4;
				padding: 13px 17px;
				color: #fff;
				border-radius: 0.25rem;
				font-size: 16px;
				cursor: pointer;
				transition: box-shadow 0.25s ease-in-out, background-color 0.3s;
				margin-top: 10px;
			}

			.login__button:hover {
				box-shadow: 0 0 0 0.25rem #DAC5EE;
			}

			.login__button:active {
				background-color: #874DBF;
				box-shadow: 0 0 0 0.35rem #DAC5EE;
			}

			.signup {
				font-size: 14px;
				text-align: center;
				margin-top: 32px;
			}

			.img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
			}

			.form-row {
				display: flex;
				gap: 20px;
			}

			.form-col {
				flex: 1;
			}

			/* =========================
			   TABS
			========================= */
			.auth-tabs {
				display: flex;
				gap: 10px;
				margin-bottom: 25px;
				padding: 6px;
				background: #f4eef9;
				border-radius: 14px;
			}

			.auth-tab {
				flex: 1;
				border: none;
				background: transparent;
				color: #867992;
				padding: 14px 16px;
				border-radius: 10px;
				font-size: 15px;
				font-weight: 600;
				cursor: pointer;
				transition: all 0.25s ease;
			}

			.auth-tab.active {
				background: #ffffff;
				color: #A26ED4;
				box-shadow: 0 8px 20px rgba(162, 110, 212, 0.14);
			}

			.tab-panel {
				display: none;
			}

			.tab-panel.active {
				display: block;
			}

			/* =========================
			   FLASH MESSAGES
			========================= */
			.alert {
				position: relative;
				width: 100%;
				padding: 16px 20px 16px 24px;
				margin-bottom: 16px;
				border: 1px solid transparent;
				border-radius: 12px;
				font-size: 15px;
				line-height: 1.5;
				font-weight: 500;
				box-shadow: 0 6px 18px rgba(0, 0, 0, 0.06);
				transition: all 0.3s ease;
			}

			.alert + .alert {
				margin-top: 12px;
			}

			.alert:hover {
				transform: translateY(-1px);
				box-shadow: 0 10px 22px rgba(0, 0, 0, 0.08);
			}

			.alert-success {
				color: #0f5132;
				background: #d1e7dd;
				border-color: #badbcc;
			}

			.alert-danger,
			.alert-error {
				color: #842029;
				background: #f8d7da;
				border-color: #f5c2c7;
			}

			.alert-warning {
				color: #664d03;
				background: #fff3cd;
				border-color: #ffecb5;
			}

			.alert-info {
				color: #055160;
				background: #cff4fc;
				border-color: #b6effb;
			}

			.alert-primary {
				color: #084298;
				background: #cfe2ff;
				border-color: #b6d4fe;
			}

			.alert-secondary {
				color: #41464b;
				background: #e2e3e5;
				border-color: #d3d6d8;
			}

			.alert-light {
				color: #636464;
				background: #fefefe;
				border-color: #fdfdfe;
			}

			.alert-dark {
				color: #141619;
				background: #d3d3d4;
				border-color: #bcbebf;
			}

			.alert::before {
				content: "";
				position: absolute;
				top: 12px;
				bottom: 12px;
				left: 0;
				width: 5px;
				border-radius: 10px;
				background: currentColor;
				opacity: 0.35;
			}

			/* =========================
			   RESPONSIVE
			========================= */
			@media only screen and (max-width: 800px) {
				.grid {
					grid-template-columns: 1fr;
					min-height: 100vh;
				}

				.order__left {
					order: 2;
					padding: 20px;
				}

				.order__right {
					order: 1;
					min-height: 300px;
				}

				.centered {
					align-items: flex-start;
				}

				.no__overflow {
					align-items: flex-start;
				}

				h4 {
					text-align: center;
				}

				.img {
					width: 100%;
					height: 300px;
				}

				.form-row {
					flex-direction: column;
					gap: 0;
				}
			}

			@media only screen and (max-height: 600px) {
				.img {
					width: 120%;
				}
			}

			@media (max-width: 767.98px) {
				.alert {
					padding: 14px 16px 14px 20px;
					font-size: 14px;
					border-radius: 10px;
				}

				.auth-tabs {
					flex-direction: column;
				}
			}
		</style>
	</head>
	<body>

		<div class="grid">
			<div class="order__left centered">
				<div class="form">
					<div class="logo">
						<img src="{{ asset('media/logo.png') }}" alt="logo" class="header-logo">
					</div>

					<h4>
						Bienvenue sur trouvemoi.eu, une plateforme haut de gamme conçue pour connecter efficacement particuliers et professionnels du bâtiment, avec exigence, qualité et performance.
					</h4>

					<div class="auth-tabs">
						<button type="button" class="auth-tab active" data-tab="tab-pro">
							Professionnel
						</button>
						<button type="button" class="auth-tab" data-tab="tab-particulier">
							Particulier
						</button>
					</div>

					{% for label, messages in app.flashes %}
						{% for message in messages %}
							<div class="alert alert-{{ label }}">
								{{ message }}
							</div>
						{% endfor %}
					{% endfor %}

					{% include('_partials/registrationPro.html.twig') %}
					{{ render(controller('App\\Controller\\SecurityController::NavTabLogin')) }}


				</div>
			</div>

			<div class="order__right centered no__overflow">
				<img class="img" src="{{ asset('image/register/register.png') }}" alt="picture">
			</div>
		</div>

		<script>
			document.addEventListener('DOMContentLoaded', function () {
				const tabs = document.querySelectorAll('.auth-tab');
				const panels = document.querySelectorAll('.tab-panel');

				tabs.forEach(tab => {
					tab.addEventListener('click', function () {
						const target = this.getAttribute('data-tab');

						tabs.forEach(btn => btn.classList.remove('active'));
						panels.forEach(panel => panel.classList.remove('active'));

						this.classList.add('active');
						document.getElementById(target).classList.add('active');
					});
				});
			});
		</script>

	</body>
</html>
