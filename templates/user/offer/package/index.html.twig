{% extends 'base.html.twig' %}

{% block title %}Mes packs{% endblock %}

{% block body %}
    <section class="inner-banner">
        <div class="container">
            <h2>Mes packs</h2>
        </div>
    </section>

    <section class="packs-page py-5" data-controller="billing-toggle" data-billing-toggle-default-value="monthly">
        <div class="container">
            <div class="row g-4">
                <div class="col-xl-12">
                    <div class="packs-card">

                        <div class="packs-header">
                            <div class="packs-header-top">
                                <div>
                                    <h3 class="packs-title mb-1">Choisissez votre pack</h3>
                                    <p class="packs-subtitle mb-0">
                                        Sélectionnez l’offre qui correspond à votre activité et augmentez votre visibilité sur la plateforme.
                                    </p>
                                </div>

                                <div class="billing-toggle-wrap">
                                <span
                                    class="billing-label billing-label-monthly active"
                                    data-billing-toggle-target="monthlyLabel"
                                    data-action="click->billing-toggle#setMonthly"
                                >
                                    Mensuel
                                </span>

                                    <button
                                        type="button"
                                        class="billing-toggle"
                                        aria-label="Changer la période de facturation"
                                        data-billing-toggle-target="toggle"
                                        data-action="click->billing-toggle#toggle"
                                    >
                                        <span class="billing-toggle-slider"></span>
                                    </button>

                                    <span
                                        class="billing-label billing-label-yearly"
                                        data-billing-toggle-target="yearlyLabel"
                                        data-action="click->billing-toggle#setYearly"
                                    >
                                    Annuel
                                    <span class="billing-save">Économisez</span>
                                </span>
                                </div>
                            </div>
                        </div>

                        <div class="packs-body">
                            <div class="row g-4 justify-content-center">

                                {% for plan in plans %}
                                    {% set isFeatured = plan.code == 'pro' %}
                                    {% set hasYearly = plan.priceYearly is not null and plan.priceYearly > 0 %}
                                    {% set yearlySavings = 0 %}

                                    {% if hasYearly and plan.priceMonthly > 0 %}
                                        {% set yearlyBase = plan.priceMonthly * 12 %}
                                        {% set yearlySavings = yearlyBase - plan.priceYearly %}
                                    {% endif %}

                                    <div class="col-lg-4 col-md-6">
                                        <div class="pack-item {{ isFeatured ? 'pack-item-featured' : '' }} {{ plan.code == 'free' ? 'pack-item-free' : '' }}">

                                            {% if isFeatured %}
                                                <div class="pack-badge">Le plus choisi</div>
                                            {% endif %}

                                            <div class="pack-top">
                                            <span class="pack-label {{ isFeatured ? 'pack-label-featured' : '' }}">
                                                {% if plan.code == 'free' %}
                                                    Découverte
                                                {% elseif plan.code == 'pro' %}
                                                    Recommandé
                                                {% elseif plan.code == 'premium' %}
                                                    Expert
                                                {% else %}
                                                    Offre
                                                {% endif %}
                                            </span>

                                                <h4 class="pack-name">{{ plan.name }}</h4>

                                                <p class="pack-description">
                                                    {% if plan.code == 'free' %}
                                                        Idéal pour découvrir la plateforme et commencer à recevoir vos premières opportunités.
                                                    {% elseif plan.code == 'pro' %}
                                                        Le meilleur équilibre pour développer votre activité et répondre plus efficacement aux annonces.
                                                    {% elseif plan.code == 'premium' %}
                                                        Une offre complète pour maximiser votre visibilité, votre crédibilité et vos demandes.
                                                    {% else %}
                                                        Une offre pensée pour accompagner votre activité.
                                                    {% endif %}
                                                </p>

                                                <div class="pack-price-block">
                                                    <div class="pack-price">
                                                    <span class="price-value monthly-price" data-billing-toggle-target="monthlyPrice">
                                                        {{ plan.priceMonthly|number_format(0, ',', ' ') }}€
                                                    </span>

                                                        {% if hasYearly %}
                                                            <span class="price-value yearly-price d-none" data-billing-toggle-target="yearlyPrice">
                                                            {{ (plan.priceYearly / 12)|number_format(0, ',', ' ') }}€
                                                        </span>
                                                        {% else %}
                                                            <span class="price-value yearly-price d-none" data-billing-toggle-target="yearlyPrice">
                                                            {{ plan.priceMonthly|number_format(0, ',', ' ') }}€
                                                        </span>
                                                        {% endif %}

                                                        <span class="price-period monthly-period" data-billing-toggle-target="monthlyPeriod">/mois</span>
                                                        <span class="price-period yearly-period d-none" data-billing-toggle-target="yearlyPeriod">/mois</span>
                                                    </div>

                                                    <div class="pack-price-meta">
                                                        <p class="monthly-meta mb-0" data-billing-toggle-target="monthlyMeta">
                                                            Facturation mensuelle, résiliable à tout moment
                                                        </p>

                                                        <p class="yearly-meta mb-0 d-none" data-billing-toggle-target="yearlyMeta">
                                                            {% if hasYearly %}
                                                                Facturé {{ plan.priceYearly|number_format(0, ',', ' ') }}€ /an
                                                                {% if yearlySavings > 0 %}
                                                                    <span class="pack-saving">
                                                                    Économie de {{ yearlySavings|number_format(0, ',', ' ') }}€
                                                                </span>
                                                                {% endif %}
                                                            {% else %}
                                                                Formule annuelle indisponible pour cette offre
                                                            {% endif %}
                                                        </p>
                                                    </div>
                                                </div>
                                            </div>

                                            <ul class="pack-features">
                                                {% if plan.features is not empty %}
                                                    {% for feature in plan.features %}
                                                        <li>{{ feature }}</li>
                                                    {% endfor %}
                                                {% else %}
                                                    <li>Aucune fonctionnalité renseignée</li>
                                                {% endif %}
                                            </ul>

                                            <div class="pack-footer">
                                                <div class="pack-actions">
                                                    <a
                                                        href="{{ path('app_user_offer_basket', { code: plan.code, billing: 'monthly', id: plan.id }) }}"
                                                        class="pack-btn {{ isFeatured ? 'pack-btn-solid' : 'pack-btn-outline' }} monthly-btn {% if hasYearly %}js-switchable-monthly{% endif %}"
                                                        data-plan="{{ plan.code }}"
                                                        data-billing="monthly"
                                                        data-billing-toggle-target="monthlyButton"
                                                    >
                                                        Choisir en mensuel
                                                    </a>

                                                    {% if hasYearly %}
                                                        <a
                                                            href="{{ path('app_user_offer_basket', { code: plan.code, billing: 'yearly', id: plan.id }) }}"
                                                            class="pack-btn pack-btn-secondary yearly-btn d-none {{ isFeatured ? 'pack-btn-secondary-featured' : '' }}"
                                                            data-plan="{{ plan.code }}"
                                                            data-billing="yearly"
                                                            data-billing-toggle-target="yearlyButton"
                                                        >
                                                            Choisir en annuel
                                                        </a>
                                                    {% endif %}
                                                </div>

                                                <p class="pack-footnote mb-0">
                                                    Sans frais cachés. Changement de formule possible à tout moment.
                                                </p>
                                            </div>
                                        </div>
                                    </div>
                                {% else %}
                                    <div class="col-12">
                                        <div class="alert alert-light border rounded-4 mb-0">
                                            Aucun pack disponible pour le moment.
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>

                            <div class="packs-note">
                                <div class="packs-note-inner">
                                    <div class="packs-note-item">
                                        <strong>Résiliation simple</strong>
                                        <span>Changez ou arrêtez votre formule quand vous le souhaitez.</span>
                                    </div>
                                    <div class="packs-note-item">
                                        <strong>Paiement sécurisé</strong>
                                        <span>Transactions protégées et gestion claire de votre abonnement.</span>
                                    </div>
                                    <div class="packs-note-item">
                                        <strong>Facturation transparente</strong>
                                        <span>Aucun coût caché, aucune surprise en cours de route.</span>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
