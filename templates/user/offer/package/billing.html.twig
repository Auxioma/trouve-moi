{% extends 'base.html.twig' %}

{% block title %}Récapitulatif du panier{% endblock %}

{% block body %}
<section class="inner-banner">
	<div class="container">
		<h2>Logo et images</h2>
	</div>
</section>

<section class="basket-page-section">
	<div class="container">
		<div class="row justify-content-center">
			<div class="col-xl-12">
					{% set priceHt = price %}
					{% set tvaRate = 20 %}
					{% set discountAmount = discountAmount is defined ? discountAmount : 0 %}
					{% set subtotalAfterDiscount = priceHt - discountAmount %}
					{% set tvaAmount = subtotalAfterDiscount * tvaRate / 100 %}
					{% set totalTtc = subtotalAfterDiscount + tvaAmount %}

					<div class="basket-shell">
						<div class="basket-shell-head">
							<div>
								<span class="basket-section-mini-title">Récapitulatif</span>
								<h2 class="basket-main-title">Votre panier</h2>
								<p class="basket-main-text">
									Vérifiez les informations ci-dessous avant de continuer vers le paiement.
								</p>
							</div>

							<div class="basket-period-chip">
								{{ billing == 'yearly' ? 'Facturation annuelle' : 'Facturation mensuelle' }}
							</div>
						</div>

						<div class="row g-4 align-items-stretch">
							<div class="col-lg-8">
								<div class="basket-card-premium h-100">
									<div class="basket-plan-box mb-4">
										<div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
											<div>
												<h3 class="basket-plan-title mb-1">{{ plan.name }}</h3>
												<p class="basket-plan-subtitle mb-0">
													{{ billing == 'yearly' ? 'Abonnement annuel' : 'Abonnement mensuel' }}
												</p>
											</div>

											<span class="basket-plan-badge">
												{{ billing == 'yearly' ? 'Annuel' : 'Mensuel' }}
											</span>
										</div>
									</div>

									<div class="basket-detail-list mb-4">
										<div class="basket-detail-line">
											<span>Montant HT</span>
											<strong>{{ priceHt|number_format(2, ',', ' ') }} €</strong>
										</div>

										{% if discountAmount > 0 %}
											<div class="basket-detail-line basket-detail-line-discount">
												<span>Bon de réduction</span>
												<strong>- {{ discountAmount|number_format(2, ',', ' ') }} €</strong>
											</div>
										{% endif %}

										<div class="basket-detail-line">
											<span>TVA ({{ tvaRate }}%)</span>
											<strong>{{ tvaAmount|number_format(2, ',', ' ') }} €</strong>
										</div>

										<div class="basket-detail-line basket-detail-line-total">
											<span>Total TTC</span>
											<strong>{{ totalTtc|number_format(2, ',', ' ') }} €</strong>
										</div>
									</div>

									<div class="row g-4">
										<div class="col-md-6">
											<label for="discount_code" class="form-label basket-label">Bon de réduction</label>
											<div class="basket-input-group">
												<input
													type="text"
													id="discount_code"
													name="discount_code"
													class="form-control basket-input"
													placeholder="Entrez votre code promo"
													value="{{ discountCode is defined ? discountCode : '' }}"
												>
												<button type="submit" name="apply_discount" value="1" class="basket-apply-btn">
													Appliquer
												</button>
											</div>
										</div>

										<div class="col-md-6">
											<label class="form-label basket-label">Choisissez votre mode de paiement</label>

											<div class="basket-payment-methods">
												<label class="basket-payment-option">
													<input
														type="radio"
														name="payment_method"
														value="stripe"
														class="basket-payment-radio"
														{{ paymentMethod is defined and paymentMethod == 'stripe' ? 'checked' : '' }}
													>
													<span class="basket-payment-card">
														<span class="basket-payment-icon">S</span>
														<span class="basket-payment-content">
															<span class="basket-payment-title">Stripe</span>
															<span class="basket-payment-text">Paiement sécurisé par carte bancaire.</span>
														</span>
													</span>
												</label>

												<label class="basket-payment-option">
													<input
														type="radio"
														name="payment_method"
														value="paypal"
														class="basket-payment-radio"
														{{ paymentMethod is defined and paymentMethod == 'paypal' ? 'checked' : '' }}
													>
													<span class="basket-payment-card">
														<span class="basket-payment-icon basket-payment-icon-paypal">P</span>
														<span class="basket-payment-content">
															<span class="basket-payment-title">PayPal</span>
															<span class="basket-payment-text">Paiement rapide via votre compte PayPal.</span>
														</span>
													</span>
												</label>
											</div>
										</div>
									</div>

									<input type="hidden" name="plan_id" value="{{ plan.id }}">
									<input type="hidden" name="billing" value="{{ billing }}">
								</div>
							</div>

							<div class="col-lg-4">
								<div class="basket-sidebar-card h-100">
									<div class="basket-sidebar-top">
										<span class="basket-sidebar-label">Montant à payer</span>
										<div class="basket-sidebar-price">
											{{ totalTtc|number_format(2, ',', ' ') }} €
										</div>
										<p class="basket-sidebar-note">
											TVA incluse. Votre formule est affichée de manière claire avant validation.
										</p>
									</div>

									<div class="basket-sidebar-summary">
										<div class="basket-sidebar-row">
											<span>Pack</span>
											<strong>{{ plan.name }}</strong>
										</div>
										<div class="basket-sidebar-row">
											<span>Période</span>
											<strong>{{ billing == 'yearly' ? 'Annuel' : 'Mensuel' }}</strong>
										</div>
										<div class="basket-sidebar-row">
											<span>HT</span>
											<strong>{{ priceHt|number_format(2, ',', ' ') }} €</strong>
										</div>
										<div class="basket-sidebar-row">
											<span>TVA</span>
											<strong>{{ tvaAmount|number_format(2, ',', ' ') }} €</strong>
										</div>
										{% if discountAmount > 0 %}
											<div class="basket-sidebar-row">
												<span>Réduction</span>
												<strong>- {{ discountAmount|number_format(2, ',', ' ') }} €</strong>
											</div>
										{% endif %}
									</div>

    
									<div class="basket-terms mb-3">
										<label class="basket-terms-check d-flex align-items-start gap-2">
											<input type="checkbox" name="accept_cgv" value="1" required>
											<span class="basket-terms-text">
												J'accepte les
												<a href="#" target="_blank" rel="noopener noreferrer">
													conditions générales de vente
												</a>
												et reconnais avoir pris connaissance des modalités de l’abonnement.
											</span>
										</label>
									</div>
									<form method="post" action="{{ path('app_user_offer_paiement') }}">
										<input type="hidden" name="plan_id" value="{{ plan.id }}">
										<input type="hidden" name="billing" value="{{ billing }}">
										<input type="hidden" name="price_ht" value="{{ price }}">
										
										<button type="submit" class="btn basket-submit-btn w-100">
											Continuer vers le paiement
										</button>
									</form>
									<p class="basket-secure-note mb-0 mt-3">
										Paiement sécurisé et traitement confidentiel de vos informations.
									</p>
								</div>
							</div>
						</div>
					</div>
			</div>
		</div>
	</div>
</section>

<style>
:root {
	--tm-primary: #A57A5A;
	--tm-primary-dark: #8D6548;
	--tm-primary-soft: #C7A58A;
	--tm-primary-pale: #E8DDD3;
	--tm-cream: #F7F3EE;
	--tm-ivory: #FCFAF7;
	--tm-border: #E8DED5;
	--tm-text: #2E241E;
	--tm-text-soft: #7A6A5D;
	--tm-white: #FFFFFF;
	--tm-shadow: 0 18px 45px rgba(77, 55, 39, 0.08);
}

.basket-terms {
	border: 1px solid #E8DED5;
	background: #FFFCF9;
	border-radius: 16px;
	padding: 14px 18px;
}

.basket-terms-check {
	display: flex;
	align-items: flex-start;
	gap: 12px;
	cursor: pointer;
	margin: 0;
}

.basket-terms-check input {
	margin-top: 4px;
	width: 18px;
	height: 18px;
	accent-color: #A57A5A;
}

.basket-terms-text {
	font-size: 14px;
	line-height: 1.6;
	color: #5E5147;
}

.basket-terms-text a {
	color: #A57A5A;
	font-weight: 600;
	text-decoration: none;
}

.basket-terms-text a:hover {
	text-decoration: underline;
}

.basket-banner {
	background:
		radial-gradient(circle at top right, rgba(165, 122, 90, 0.12), transparent 30%),
		linear-gradient(180deg, #FCFAF7 0%, #F7F3EE 100%);
	padding: 70px 0 55px;
	border-bottom: 1px solid rgba(165, 122, 90, 0.10);
}

.basket-banner-content {
	max-width: 760px;
}

.basket-kicker {
	display: inline-block;
	font-size: 12px;
	font-weight: 700;
	letter-spacing: 0.18em;
	text-transform: uppercase;
	color: var(--tm-primary);
	margin-bottom: 14px;
}

.basket-banner h1 {
	font-size: 44px;
	line-height: 1.08;
	font-weight: 700;
	color: var(--tm-text);
	margin-bottom: 14px;
}

.basket-banner p {
	font-size: 16px;
	line-height: 1.7;
	color: var(--tm-text-soft);
	max-width: 680px;
	margin-bottom: 0;
}

.basket-page-section {
	background: linear-gradient(180deg, #fff 0%, #fcfaf7 100%);
	padding: 56px 0 90px;
}

.basket-shell {
	background: rgba(255, 255, 255, 0.82);
	backdrop-filter: blur(14px);
	-webkit-backdrop-filter: blur(14px);
	border: 1px solid rgba(232, 222, 213, 0.85);
	border-radius: 32px;
	padding: 34px;
	box-shadow: 0 22px 60px rgba(77, 55, 39, 0.08);
}

.basket-shell-head {
	display: flex;
	align-items: flex-start;
	justify-content: space-between;
	gap: 20px;
	margin-bottom: 30px;
}

.basket-section-mini-title {
	display: inline-block;
	font-size: 12px;
	font-weight: 700;
	letter-spacing: 0.16em;
	text-transform: uppercase;
	color: var(--tm-primary);
	margin-bottom: 10px;
}

.basket-main-title {
	font-size: 34px;
	line-height: 1.12;
	font-weight: 700;
	color: var(--tm-text);
	margin-bottom: 10px;
}

.basket-main-text {
	font-size: 15px;
	line-height: 1.7;
	color: var(--tm-text-soft);
	margin-bottom: 0;
	max-width: 650px;
}

.basket-period-chip {
	display: inline-flex;
	align-items: center;
	justify-content: center;
	padding: 12px 18px;
	border-radius: 999px;
	background: rgba(165, 122, 90, 0.10);
	color: var(--tm-primary-dark);
	font-size: 13px;
	font-weight: 700;
	white-space: nowrap;
}

.basket-card-premium,
.basket-sidebar-card {
	background: linear-gradient(180deg, rgba(252, 250, 247, 0.96) 0%, rgba(255,255,255,0.98) 100%);
	border: 1px solid var(--tm-border);
	border-radius: 28px;
	box-shadow: var(--tm-shadow);
	padding: 26px;
}

.basket-plan-box {
	background: linear-gradient(180deg, #FCFAF7 0%, #F3ECE4 100%);
	border: 1px solid var(--tm-border);
	border-radius: 22px;
	padding: 22px;
}

.basket-plan-title {
	font-size: 28px;
	font-weight: 700;
	color: var(--tm-text);
}

.basket-plan-subtitle {
	font-size: 15px;
	color: var(--tm-text-soft);
}

.basket-plan-badge {
	display: inline-flex;
	align-items: center;
	justify-content: center;
	padding: 9px 15px;
	border-radius: 999px;
	background: var(--tm-primary);
	color: #fff;
	font-size: 13px;
	font-weight: 700;
}

.basket-detail-list {
	border: 1px solid #EEE3DA;
	border-radius: 22px;
	padding: 12px 22px;
	background: #FFFCF9;
}

.basket-detail-line {
	display: flex;
	justify-content: space-between;
	align-items: center;
	gap: 16px;
	padding: 15px 0;
	border-bottom: 1px solid #EEE3DA;
	color: #5E5147;
	font-size: 15px;
}

.basket-detail-line:last-child {
	border-bottom: none;
}

.basket-detail-line strong {
	color: var(--tm-text);
	font-weight: 700;
}

.basket-detail-line-discount strong {
	color: #198754;
}

.basket-detail-line-total {
	padding-top: 18px;
	margin-top: 4px;
	border-top: 1px dashed #D8C8BA;
	border-bottom: none;
	font-size: 17px;
}

.basket-detail-line-total strong {
	font-size: 24px;
	color: var(--tm-primary);
}

.basket-label {
	font-size: 14px;
	font-weight: 700;
	color: var(--tm-text);
	margin-bottom: 10px;
}

.basket-input-group {
	display: flex;
	gap: 10px;
}

.basket-input {
	height: 54px;
	border-radius: 18px;
	border: 1px solid #DCCFC4;
	padding: 0 18px;
	background: #fff;
	box-shadow: none;
}

.basket-input:focus {
	border-color: var(--tm-primary);
	box-shadow: 0 0 0 0.2rem rgba(165, 122, 90, 0.12);
}

.basket-apply-btn {
	height: 54px;
	border: none;
	border-radius: 18px;
	padding: 0 20px;
	background: #2E241E;
	color: #fff;
	font-weight: 700;
	transition: 0.25s ease;
	white-space: nowrap;
}

.basket-apply-btn:hover {
	background: var(--tm-primary);
}

.basket-payment-methods {
	display: grid;
	grid-template-columns: 1fr;
	gap: 14px;
}

.basket-payment-option {
	display: block;
	cursor: pointer;
	margin: 0;
}

.basket-payment-radio {
	position: absolute;
	opacity: 0;
	pointer-events: none;
}

.basket-payment-card {
	display: flex;
	align-items: center;
	gap: 14px;
	padding: 18px;
	border: 1px solid #E8DED5;
	border-radius: 20px;
	background: #FFFCF9;
	transition: all 0.25s ease;
	min-height: 84px;
}

.basket-payment-option:hover .basket-payment-card {
	border-color: #C7A58A;
	box-shadow: 0 12px 25px rgba(77, 55, 39, 0.08);
	transform: translateY(-1px);
}

.basket-payment-radio:checked + .basket-payment-card {
	border-color: #A57A5A;
	background: linear-gradient(180deg, #FCFAF7 0%, #F3ECE4 100%);
	box-shadow: 0 14px 30px rgba(165, 122, 90, 0.14);
}

.basket-payment-icon {
	width: 46px;
	height: 46px;
	min-width: 46px;
	border-radius: 14px;
	background: #2E241E;
	color: #fff;
	display: flex;
	align-items: center;
	justify-content: center;
	font-size: 18px;
	font-weight: 700;
}

.basket-payment-icon-paypal {
	background: #A57A5A;
}

.basket-payment-content {
	display: flex;
	flex-direction: column;
}

.basket-payment-title {
	font-size: 15px;
	font-weight: 700;
	color: #2E241E;
	margin-bottom: 4px;
}

.basket-payment-text {
	font-size: 14px;
	color: #7A6A5D;
	line-height: 1.5;
}

.basket-sidebar-card {
	display: flex;
	flex-direction: column;
	justify-content: space-between;
}

.basket-sidebar-top {
	padding-bottom: 22px;
	border-bottom: 1px solid #EEE3DA;
	margin-bottom: 22px;
}

.basket-sidebar-label {
	display: inline-block;
	font-size: 12px;
	font-weight: 700;
	letter-spacing: 0.14em;
	text-transform: uppercase;
	color: var(--tm-primary);
	margin-bottom: 10px;
}

.basket-sidebar-price {
	font-size: 38px;
	line-height: 1;
	font-weight: 700;
	color: var(--tm-text);
	margin-bottom: 12px;
}

.basket-sidebar-note {
	font-size: 14px;
	line-height: 1.7;
	color: var(--tm-text-soft);
	margin-bottom: 0;
}

.basket-sidebar-summary {
	display: grid;
	gap: 12px;
	margin-bottom: 24px;
}

.basket-sidebar-row {
	display: flex;
	justify-content: space-between;
	align-items: center;
	gap: 16px;
	font-size: 14px;
	color: var(--tm-text-soft);
}

.basket-sidebar-row strong {
	color: var(--tm-text);
	font-weight: 700;
}

.basket-submit-btn {
	background: linear-gradient(135deg, var(--tm-primary) 0%, var(--tm-primary-dark) 100%);
	color: #fff;
	border: none;
	border-radius: 999px;
	padding: 16px 28px;
	font-weight: 700;
	font-size: 15px;
	transition: 0.25s ease;
	box-shadow: 0 14px 28px rgba(165, 122, 90, 0.20);
}

.basket-submit-btn:hover {
	transform: translateY(-1px);
	color: #fff;
	box-shadow: 0 18px 34px rgba(165, 122, 90, 0.28);
}

.basket-secure-note {
	font-size: 13px;
	line-height: 1.7;
	color: var(--tm-text-soft);
	text-align: center;
	margin-top: 14px;
}

@media (max-width: 991px) {
	.basket-shell-head {
		flex-direction: column;
		align-items: flex-start;
	}

	.basket-banner h1 {
		font-size: 34px;
	}

	.basket-main-title {
		font-size: 28px;
	}
}

@media (max-width: 767px) {
	.basket-page-section {
		padding: 34px 0 60px;
	}

	.basket-shell {
		padding: 22px;
		border-radius: 24px;
	}

	.basket-banner {
		padding: 56px 0 42px;
	}

	.basket-banner h1 {
		font-size: 28px;
	}

	.basket-plan-title {
		font-size: 24px;
	}

	.basket-sidebar-price {
		font-size: 30px;
	}

	.basket-input-group {
		flex-direction: column;
	}

	.basket-apply-btn {
		width: 100%;
	}
}
</style>
{% endblock %}