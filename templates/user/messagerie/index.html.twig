{% extends 'base.html.twig' %}

{% block title %}Messagerie{% endblock %}

{% block body %}
    <section class="inner-banner">
        <div class="container">
            <h2>Messagerie</h2>
        </div>
    </section>

    <section class="messagerie-page py-5">
        <div class="container">
            <div class="row g-4">
                {% include '_partials/nav_bar_artisant.html.twig' %}

                <div class="col-xl-8">
                    <div class="messagerie-card">

                        <div class="messagerie-header">
                            <div>
                                <h3 class="messagerie-title mb-1">Boîte de réception</h3>
                                <p class="messagerie-subtitle mb-0">
                                    {{ discussions|length }} discussion{{ discussions|length > 1 ? 's' : '' }}
                                </p>
                            </div>
                        </div>

                        <div class="artisan-message-list">
                            {% for discussion in discussions %}
                                <a href="{{ path('app_user_messagerie_show', { id: discussion.conversation.id }) }}"
                                   class="artisan-message-list-item">

                                    <div class="artisan-message-list-avatar-wrapper">
                                        <div class="artisan-message-list-avatar">
                                            {% if discussion.user.imageName is defined and discussion.user.imageName %}
                                                <img
                                                    src="{{ asset('uploads/users/' ~ discussion.user.imageName) }}"
                                                    alt="{{ discussion.user.firstName }}"
                                                >
                                            {% else %}
                                                <span>
												{{ discussion.user.firstName|default('U')|slice(0, 1)|upper }}
											</span>
                                            {% endif %}
                                        </div>
                                    </div>

                                    <div class="artisan-message-list-main">
                                        <div class="artisan-message-list-topline">
                                            <p class="artisan-message-list-title">
											<span class="artisan-message-list-user-name">
												{{ discussion.user.firstName|default('') }} {{ discussion.user.lastName|default('') }}
											</span>

                                                {% if discussion.conversation.title is defined and discussion.conversation.title %}
                                                    <span class="artisan-message-list-separator">•</span>
                                                    <span class="artisan-message-list-project-title">
													{{ discussion.conversation.title }}
												</span>
                                                {% endif %}
                                            </p>

                                            <span class="artisan-message-list-date">
											{% if discussion.lastMessage and discussion.lastMessage.createdAt %}
                                                {{ discussion.lastMessage.createdAt|date('d M') }}
                                            {% endif %}
										</span>
                                        </div>

                                        <div class="artisan-message-list-bottomline">
                                            <p class="artisan-message-list-preview">
                                                {% if discussion.lastMessage and discussion.lastMessage.content %}
                                                    {{ discussion.lastMessage.content|striptags|u.truncate(85, '...') }}
                                                {% else %}
                                                    Aucun message pour le moment
                                                {% endif %}
                                            </p>

                                            {% if discussion.lastMessage is defined and discussion.lastMessage and discussion.lastMessage.isRead is defined and not discussion.lastMessage.isRead %}
                                                <span class="artisan-message-list-unread-dot"></span>
                                            {% endif %}
                                        </div>
                                    </div>
                                </a>
                            {% else %}
                                <div class="messagerie-empty">
                                    <div class="messagerie-empty-icon">✉️</div>
                                    <h4>Aucune discussion</h4>
                                    <p class="mb-0">Vos conversations apparaîtront ici.</p>
                                </div>
                            {% endfor %}
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
