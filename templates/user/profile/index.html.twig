{% extends 'base.html.twig' %}

{% block title %}Hello ProfileController!{% endblock %}

{% block body %}
	<section class="inner-banner">
		<div class="container">
			<h2>Votre profile</h2>
		</div>
	</section>

	<section class="properties-detail bg-white p-100">
		<div class="container">
			<div class="row g-4">
				{% include '_partials/nav_bar_artisant.html.twig' %}

				<div class="col-xl-8">
					{{ form_start(form, {
						attr: {
							class: 'artisan-form-page'
						}
					}) }}

						<div class="house-detail mb-4">
							<div class="container">
								<div class="row g-4">
									<div class="col-12">
										<div class="artisan-card">
											<div class="artisan-section-header mb-4">
												<h2>Informations personnelles</h2>
												<p>Les informations principales de votre compte.</p>
											</div>

											<div class="row g-3">
												{{ form_row(form.firstName) }}
												{{ form_row(form.lastName) }}
												{{ form_row(form.email) }}
												{{ form_row(form.phoneNumber) }}

											</div>
										</div>
									</div>
								</div>
							</div>
						</div>

						<div class="house-detail mb-4">
							<div class="container">
								<div class="row g-4">
									<div class="col-12">
										<div class="artisan-card">
											<div class="artisan-section-header mb-4">
												<h2>Informations entreprise</h2>
												<p>Les données professionnelles visibles sur votre fiche.</p>
											</div>

											<div class="row g-3">
												{{ form_row(form.compagny) }}
												{{ form_row(form.siren) }}
												{{ form_row(form.website) }}
											</div>
										</div>
									</div>
								</div>
							</div>
						</div>

						<div class="house-detail mb-4">
							<div class="container">
								<div class="row g-4">
									<div class="col-12">
										<div class="artisan-card">
											<div class="artisan-section-header mb-4">
												<h2>Adresse et localisation</h2>
												<p>Indiquez votre localisation professionnelle.</p>
											</div>

											<div class="row g-3">
												{{ form_row(form.address) }}
												{{ form_row(form.postalCode) }}
												{{ form_row(form.city) }}
											</div>
										</div>
									</div>
								</div>
							</div>
						</div>

						<div class="house-detail mb-4">
							<div class="container">
								<div class="row g-4">
									<div class="col-12">
										<div class="artisan-card">
											<div class="artisan-section-header mb-4">
												<h2>Présentation</h2>
												<p>Décrivez votre savoir-faire, vos spécialités et votre expérience.</p>
											</div>

											<div class="row g-3">
												{{ form_row(form.description) }}
											</div>
										</div>
									</div>
								</div>
							</div>
						</div>

						<div class="house-detail mb-4">
							<div class="container">
								<div class="row g-4">
									<div class="col-12">
										<div class="artisan-card">
											<div class="artisan-section-header mb-4">
											<h2>Description de votre entreprise</h2>
											<p>Présentez votre entreprise, votre expertise et votre expérience.</p>
											</div>
											<div class="row g-3">
												{{ form_row(form.grandeDescription) }}
											</div>
										</div>
									</div>
								</div>
							</div>
						</div>

						<div class="house-detail mb-4">
							<div class="container">
								<div class="row g-4">
									<div class="col-12">
										<div class="artisan-card artisan-card-light">
											<div class="artisan-section-header mb-4">
												<h2>Informations techniques</h2>
												<p>Ces champs sont généralement gérés automatiquement.</p>
											</div>
											<div class="row g-3">
												{{ form_row(form.activity) }}
												<div class="col-12">
													
													<div class="row" id="services-container"></div>
												</div>
											</div>
										</div>
									</div>
								</div>
							</div>
						</div>
						<div class="d-flex justify-content-end">
							<button type="submit" class="btn btn-dark rounded-pill px-4 py-2">
								Enregistrer
							</button>
						</div>

					{{ form_end(form) }}
				</div>
			</div>
		</div>
	</section>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const activityField = document.querySelector('[name$="[activity]"]');
    const servicesContainer = document.querySelector('#services-container');
    const urlTemplate = '{{ path('ajax_services_by_activity', { id: '__ID__' }) }}';

    if (!activityField || !servicesContainer) {
        return;
    }

    activityField.addEventListener('change', async function () {
        const activityId = this.value;

        // 🔥 sauvegarde des services cochés
        const selectedValues = new Set(
            Array.from(document.querySelectorAll('input[name="profile[services][]"]:checked'))
                .map(el => el.value)
        );

        // reset
        servicesContainer.innerHTML = '';

        if (!activityId) {
            return;
        }

        try {
            const response = await fetch(urlTemplate.replace('__ID__', activityId), {
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            });

            if (!response.ok) {
                throw new Error('Erreur AJAX');
            }

            const services = await response.json();

            services.forEach(service => {

                // 👉 COLONNE (col-6 responsive)
                const col = document.createElement('div');
                col.classList.add('col-6');

                // 👉 wrapper bootstrap
                const wrapper = document.createElement('div');
                wrapper.classList.add('form-check');

                // 👉 checkbox
                const input = document.createElement('input');
                input.type = 'checkbox';
                input.classList.add('form-check-input');

                // ⚠️ adapte "profile" si besoin
                input.name = 'profile[services][]';
                input.value = service.id;
                input.id = `profile_services_${service.id}`;

                // 👉 restore checked state
                if (selectedValues.has(String(service.id))) {
                    input.checked = true;
                }

                // 👉 label
                const label = document.createElement('label');
                label.classList.add('form-check-label');
                label.setAttribute('for', input.id);
                label.textContent = service.name;

                // assemblage
                wrapper.appendChild(input);
                wrapper.appendChild(label);
                col.appendChild(wrapper);
                servicesContainer.appendChild(col);
            });

        } catch (error) {
            console.error('Erreur chargement services:', error);

            servicesContainer.innerHTML = `
                <div class="col-12 text-danger">
                    Impossible de charger les services
                </div>
            `;
        }
    });

    // 🔥 trigger au chargement si valeur déjà sélectionnée
    if (activityField.value) {
        activityField.dispatchEvent(new Event('change'));
    }
});
</script>
{% endblock %}