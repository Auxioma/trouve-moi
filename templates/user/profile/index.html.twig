{% extends 'base.html.twig' %}

{% block title %}Hello ProfileController!{% endblock %}

{% block body %}
 <section class="container-fluid user_profile_hero_section px-0">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-5">
                    <div class="user_profile_hero_content">
                        <h1 class="user_profile_hero_title">Créer ma fiche artisan</h1>
                        <p class="user_profile_hero_text">
                            Créez et personnalisez votre profil
                            pour attirer plus de clients.
                        </p>
                        <button class="btn user_profile_btn_cta">Créer ma profil gratuitement</button>
                        <div class="user_profile_hero_note">
                            Déjà plus de 5,000 artisans et prestataires inscrits !
                        </div>
                    </div>
                </div>

                <div class="col-lg-7">
                    <div class="user_profile_hero_image_box">
                        <img src="zozo.jpeg" alt="Artisan">
                    </div>
                </div>
            </div>
        </div>

        <div class="user_profile_hero_curve"></div>
    </section>

    <!-- MAIN -->
    <section class="container-fluid user_profile_main_section px-0">
        <div class="container">
            <h2 class="user_profile_main_title">
                Remplissez les champs ci-dessous <span>pour créer votre fiche artisan.</span>
            </h2>

            <div class="row g-4">
                <!-- LEFT COLUMN -->
                <div class="col-lg-7">
                    <div class="user_profile_card">
                        <h3 class="user_profile_card_title">Informations Générales</h3>

                        <div class="d-flex flex-column flex-md-row gap-3 align-items-start mb-3">
                            <div class="user_profile_upload_box">
                                <div class="user_profile_upload_preview">
                                    <img src="zozo.jpeg" alt="Photo artisan">
                                </div>
                                <div class="user_profile_upload_label">Ajouter une photo</div>
                            </div>

                            <div class="flex-grow-1 w-100">
                                <input type="text" class="form-control user_profile_form_control mb-3" value="Martin Plomberie">
                                <select class="form-select user_profile_form_select mb-3">
                                    <option selected>Plombier</option>
                                    <option>Électricien</option>
                                    <option>Peintre</option>
                                </select>
                                <input type="text" class="form-control user_profile_form_control mb-3" value="Lyon">

                                <div class="row g-3">
                                    <div class="col-md-5">
                                        <input type="text" class="form-control user_profile_form_control" value="06 12 34 56 78">
                                    </div>
                                    <div class="col-md-7">
                                        <input type="email" class="form-control user_profile_form_control" value="martin@example.com">
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="user_profile_section_divider"></div>

                        <div class="mb-3">
                            <h4 class="user_profile_card_title mb-2">
                                Description de vos services <span class="user_profile_inline_note">(minimum 300 caractères)</span>
                            </h4>

                            <textarea class="form-control user_profile_textarea">Martin Plomberie est une entreprise familiale spécialisée dans les travaux de plomberie à Lyon. Nous intervenons rapidement pour vos dépannages, installations et rénovations. Avec plus de 10 ans d'expérience, nous sommes à votre service pour assurer la qualité de nos interventions.</textarea>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <input type="text" class="form-control user_profile_form_control" placeholder="Mots-clés (séparés par des virgules)">
                            </div>
                            <div class="col-md-6">
                                <div class="input-group">
                                    <span class="input-group-text user_profile_input_group_text">99+</span>
                                    <input type="text" class="form-control user_profile_form_control" value="par heure">
                                </div>
                            </div>
                        </div>

                        <h4 class="user_profile_card_title">Labels et Disponibilité</h4>

                        <div class="user_profile_check_grid mb-4">
                            <label class="user_profile_check_line">
                                <input type="checkbox" checked>
                                <span>Dépannage plomberie</span>
                            </label>
                            <label class="user_profile_check_line">
                                <input type="checkbox" checked>
                                <span>Recherche de fuite</span>
                            </label>
                            <label class="user_profile_check_line">
                                <input type="checkbox" checked>
                                <span>Installation salle de bains</span>
                            </label>
                            <label class="user_profile_check_line">
                                <input type="checkbox">
                                <span>Entretien chauffe-eau</span>
                            </label>
                            <label class="user_profile_check_line">
                                <input type="checkbox" checked>
                                <span>Recherche de fuite</span>
                            </label>
                            <label class="user_profile_check_line">
                                <input type="checkbox" checked>
                                <span>Débouchage canalisation</span>
                            </label>
                        </div>

                        <div class="user_profile_section_divider"></div>

                        <div class="user_profile_info_row">
                            <div class="user_profile_info_label">Adresse complète<br><span class="fw-normal">[Exemple.] Teaablature</span></div>
                            <input type="text" class="user_profile_info_input" value="123 rue de la Plomberie, 69007 Lyon">
                        </div>

                        <div class="user_profile_info_row">
                            <div class="user_profile_info_label">Lien de votre site</div>
                            <input type="text" class="user_profile_info_input" value="https://www.martin-plomberie-lyon.com">
                        </div>

                        <div class="user_profile_info_row mb-0">
                            <div class="user_profile_info_label">SIRET</div>
                            <input type="text" class="user_profile_info_input" value="12345678900014">
                        </div>
                    </div>
                </div>

                <!-- RIGHT COLUMN -->
                <div class="col-lg-5">
                    <div class="user_profile_card mb-4">
                        <h3 class="user_profile_side_title">
                            Remplissez le formulaire<br>
                            pour inscrire votre entreprise !
                        </h3>

                        <select class="form-select user_profile_form_select mb-3">
                            <option selected>Nom de l’entreprise</option>
                        </select>

                        <input type="text" class="form-control user_profile_form_control mb-3" value="Vious">

                        <div class="user_profile_section_divider"></div>

                        <div class="user_profile_success_line">
                            <span class="user_profile_success_icon">✔</span>
                            <span>Disponibilité</span>
                        </div>

                        <div class="user_profile_success_line">
                            <span class="user_profile_success_icon">✔</span>
                            <span><em>Disponible cette semaine</em></span>
                        </div>

                        <div class="user_profile_section_divider"></div>

                        <h4 class="user_profile_card_title mb-3">Travaux réalisés</h4>

                        <div class="d-grid gap-2 mb-4">
                            <label class="user_profile_check_line">
                                <input type="checkbox" checked>
                                <span>Dépannage plomberie</span>
                            </label>
                            <label class="user_profile_check_line">
                                <input type="checkbox" checked>
                                <span>Installation salle de bains</span>
                            </label>
                            <label class="user_profile_check_line">
                                <input type="checkbox" checked>
                                <span>Recherche de fuite</span>
                            </label>
                            <label class="user_profile_check_line">
                                <input type="checkbox">
                                <span>Entretien chauffe-eau</span>
                            </label>
                            <label class="user_profile_check_line">
                                <input type="checkbox" checked>
                                <span>Débouchage canalisation</span>
                            </label>
                        </div>

                        <select class="form-select user_profile_form_select user_profile_side_select mb-3">
                            <option selected>60 € &nbsp; par heure</option>
                        </select>

                        <button class="btn user_profile_btn_blue">Ajouter des photos</button>
                    </div>

                    <div class="user_profile_info_notice mb-4">
                        ✔ Votre fiche sera vérifiée avant publication.
                    </div>

                    <button class="btn user_profile_btn_save">Enregistrer ma fiche</button>
                </div>
            </div>
        </div>
    </section>

    
{% endblock %}
