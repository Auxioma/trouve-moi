{% extends 'base.html.twig' %}

{% block title %}Demande de devis{% endblock %}

{% block body %}

    {% set isPartial = item.profileStatus is not null and item.profileStatus.value == 'profil_partiel' %}

    <div class="hero-banner" style="background-image: url('{{ asset('image/entreprise/01.png') }}');">
        <div class="hero-overlay"></div>

        <div class="container h-100 d-flex flex-column justify-content-end position-relative">
            <div class="entreprise-cadre-marge text-white">
                <div class="mb-2">
                    <span class="entreprise-metier me-2">
                        {{ item.activity.name }}
                    </span>
                    <span class="entreprise-etoile me-2 {{ isPartial ? 'blur-content' : '' }}">
                        {{ isPartial ? '******' : '★ 4.9' }}
                    </span>
                    <span class="entreprise-nombre-avis  {{ isPartial ? 'blur-content' : '' }}">
                        {{ isPartial ? '*************' : '(150+ avis)' }}
                    </span>
                </div>

                {# visible #}
                <h1 class="entreprise-nom my-2">
                    {% if item.compagny is not empty and item.compagny != 'N/A' %}
                        {{ item.compagny|u.truncate(25, '...') }}
                    {% else %}
                        {{ item.firstname }}
                    {% endif %}
                </h1>

                <div class="entreprise-infos d-flex flex-wrap gap-3">
                    {# visible #}
                    <span>
                        <i class="fa-solid fa-location-dot me-2"></i>{{ item.city }}, France
                    </span>

                    <span class="{{ isPartial ? 'blur-content' : '' }}">
                        <i class="fa-solid fa-calendar-days me-2"></i>
                        {{ isPartial ? '***************' : 'Inscrit en ' ~ (item.createdAt|format_date(pattern='MMMM yyyy', locale='fr')|capitalize) }}
                    </span>

                    <span class="{{ isPartial ? 'blur-content' : '' }}">
                        <i class="fa-solid fa-shield me-2"></i>
                        {{ isPartial ? '********************************' : 'Assurance Professionnelle Certifiée' }}
                    </span>
                </div>
            </div>
        </div>
    </div>

    <div class="container mt-5">
        <div class="row g-4">
            <div class="col-lg-8">
                <section>
                    <span class="entreprise-titre {{ isPartial ? 'blur-content' : '' }}">
                        {{ isPartial ? '*************' : 'LE VISIONNAIRE' }}
                    </span>

                    <h2 class="entreprise-slogan {{ isPartial ? 'blur-content' : '' }}">
                        {{ isPartial ? '*******************************' : "Redéfinir l'Élégance Brutaliste" }}
                    </h2>

                    <p class="entreprise-description {{ isPartial ? 'blur-content' : '' }}">
                        {{ isPartial
                            ? '**********************************************************************************************************************'
                            : item.grandeDescription
                        }}
                    </p>

                    <ul class="entreprise-services list-unstyled d-flex flex-wrap gap-3 {{ isPartial ? 'blur-content' : '' }}">
                        <li>{{ isPartial ? '***********' : 'Béton Poli' }}</li>
                        <li>{{ isPartial ? '***********' : 'Béton Ciré' }}</li>
                        <li>{{ isPartial ? '*****************' : 'Design Industriel' }}</li>
                        <li>{{ isPartial ? '***********************' : 'Matériaux Éco-certifiés' }}</li>
                    </ul>
                </section>

                <section class="catalogue-services">
                    <span class="entreprise-titre {{ isPartial ? 'blur-content' : '' }}">
                        {{ isPartial ? '*************' : 'LE VISIONNAIRE' }}
                    </span>

                    <h2 class="entreprise-slogan-realisation mb-3 {{ isPartial ? 'blur-content' : '' }}">
                        {{ isPartial ? '***********************' : 'Réalisations Récentes' }}
                    </h2>

                    <div class="row g-3">
{% for image in item.pictures %}
    <div class="col-md-4 col-sm-6">
        <img
            src="{{ vich_uploader_asset(image, 'imageFile') ?: asset('image/artisan/01.png') }}"
            alt="{{ item.name ?? 'Artisan' }}"
            class="img-fluid w-100 rounded-2"
            width="300"
            height="300"
        />
    </div>
{% endfor %}
                    </div>
                </section>

                <section class="catalogue-services">
                    <span class="entreprise-titre {{ isPartial ? 'blur-content' : '' }}">
                        {{ isPartial ? '*************' : 'LE VISIONNAIRE' }}
                    </span>

                    <h2 class="entreprise-slogan-catalogue mb-3 {{ isPartial ? 'blur-content' : '' }}">
                        {{ isPartial ? '**********************' : 'Catalogue de Services' }}
                    </h2>

                    <div class="service-table {{ isPartial ? 'blur-content' : '' }}">
                        <div class="service-table__head row g-0">
                            <div class="col-6">
                                <div class="service-table__cell service-table__cell--head {{ isPartial ? 'blur-content' : '' }}">
                                    {{ isPartial ? '********' : 'SERVICE' }}
                                </div>
                            </div>
                            <div class="col-3">
                                <div class="service-table__cell service-table__cell--head">
                                    {{ isPartial ? '***********' : 'À PARTIR DE' }}
                                </div>
                            </div>
                            <div class="col-3">
                                <div class="service-table__cell service-table__cell--head">
                                    {{ isPartial ? '*****' : 'DURÉE' }}
                                </div>
                            </div>
                        </div>

                        <div class="service-table__body row g-0 bg-white">
                            <div class="col-6">
                                <div class="service-table__cell">
                                    <h5 class="entreprise-service-titre-h5 mb-1">
                                        {{ isPartial ? '*******************' : 'Sols en Béton Ciré' }}
                                    </h5>
                                    <p class="entreprise-service-description mb-0">
                                        {{ isPartial ? '*************************************' : 'Zones résidentielles à fort passage' }}
                                    </p>
                                </div>
                            </div>
                            <div class="col-3">
                                <div class="service-table__cell service-table__price">
                                    {{ isPartial ? '********' : '120 € / m²' }}
                                </div>
                            </div>
                            <div class="col-3">
                                <div class="service-table__cell service-table__duration">
                                    {{ isPartial ? '*******' : '5-7 jours' }}
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="catalogue-services">
                        <h2 class="entreprise-button {{ isPartial ? 'blur-content' : '' }}">
                            {{ isPartial ? '***************************' : 'Spécialisations & Savoir-faire' }}
                        </h2>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="padding-specialisation bg-white {{ isPartial ? 'blur-content' : '' }}">
                                    <span class="entreprise-specialisation">
                                        {{ isPartial ? '***********' : 'Béton Poli' }}
                                    </span>
                                    <p class="entreprise-specialisation-description">
                                        {{ isPartial ? '***************************************' : 'Finition lisse et brillante pour sols et murs' }}
                                    </p>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="padding-specialisation bg-white {{ isPartial ? 'blur-content' : '' }}">
                                    <span class="entreprise-specialisation">
                                        {{ isPartial ? '***********' : 'Béton Ciré' }}
                                    </span>
                                    <p class="entreprise-specialisation-description">
                                        {{ isPartial ? '********************************************' : 'Revêtement contemporain pour espaces intérieurs' }}
                                    </p>
                                </div>
                            </div>

                            <div class="col-md-6 my-4">
                                <div class="padding-specialisation bg-white {{ isPartial ? 'blur-content' : '' }}">
                                    <span class="entreprise-specialisation">
                                        {{ isPartial ? '*****************' : 'Design Industriel' }}
                                    </span>
                                    <p class="entreprise-specialisation-description">
                                        {{ isPartial ? '************************************************' : 'Conception d’ambiances modernes et architecturales' }}
                                    </p>
                                </div>
                            </div>

                            <div class="col-md-6 my-4">
                                <div class="padding-specialisation bg-white {{ isPartial ? 'blur-content' : '' }}">
                                    <span class="entreprise-specialisation">
                                        {{ isPartial ? '************************' : 'Matériaux Éco-responsables' }}
                                    </span>
                                    <p class="entreprise-specialisation-description">
                                        {{ isPartial ? '********************************************' : 'Choix durables pour des projets plus respectueux' }}
                                    </p>
                                </div>
                            </div>

                            <div class="garantie-eco-responsable-border {{ isPartial ? 'blur-content' : '' }}">
                                <span class="garantie-devenal-ets">
                                    <i class="fa-solid fa-shield"></i>
                                    {{ isPartial ? '*******************' : 'Garantie Décennale' }}
                                </span>
                                <span class="garantie-devenal-eco-responsables">
                                    <i class="fa-solid fa-fire"></i>
                                    {{ isPartial ? '*****************************' : 'Matériaux Éco-responsables' }}
                                </span>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="catalogue-services">
                    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
                        <h2 class="entreprise-slogan-catalogue mb-0 {{ isPartial ? 'blur-content' : '' }}">
                            {{ isPartial ? '************' : 'Avis Clients' }}
                        </h2>

                        <div class="entreprise-avis-badge {{ isPartial ? 'blur-content' : '' }}">
                            <strong>{{ isPartial ? '*****' : '4.8/5' }}</strong>
                            <span>{{ isPartial ? '******************************' : 'Note globale basée sur 124 avis' }}</span>
                        </div>
                    </div>

                    <div class="entreprise-avis bg-white mb-3 {{ isPartial ? 'blur-content' : '' }}">
                        <div class="entreprise-avis-avatar">
                            <img src="{{ asset('image/artisan/04.png') }}" alt="Photo de Jean-Marc L." class="entreprise-avis-image">
                        </div>

                        <div class="entreprise-avis-contenu">
                            <div class="entreprise-avis-entete">
                                <div class="entreprise-avis-identite">
                                    <h4 class="entreprise-avis-nom">{{ isPartial ? '************' : 'Jean-Marc L.' }}</h4>
                                    <div class="entreprise-avis-etoiles">{{ isPartial ? '*****' : '★★★★★' }}</div>
                                </div>

                                <p class="entreprise-avis-date">{{ isPartial ? '***************' : 'Il y a 2 semaines' }}</p>
                            </div>

                            <p class="entreprise-avis-commentaire">
                                {{ isPartial
                                    ? '********************************************************************************************************'
                                    : 'Un travail d’orfèvre sur notre sol de salon en béton ciré. L’Atelier du Béton a su nous conseiller sur la teinte parfaite. Résultat impeccable et équipe très ponctuelle.'
                                }}
                            </p>
                        </div>
                    </div>

                    <div class="entreprise-avis bg-white mb-3 {{ isPartial ? 'blur-content' : '' }}">
                        <div class="entreprise-avis-avatar">
                            <img src="{{ asset('image/artisan/04.png') }}" alt="Photo de Jean-Marc L." class="entreprise-avis-image">
                        </div>

                        <div class="entreprise-avis-contenu">
                            <div class="entreprise-avis-entete">
                                <div class="entreprise-avis-identite">
                                    <h4 class="entreprise-avis-nom">{{ isPartial ? '************' : 'Jean-Marc L.' }}</h4>
                                    <div class="entreprise-avis-etoiles">{{ isPartial ? '*****' : '★★★★★' }}</div>
                                </div>

                                <p class="entreprise-avis-date">{{ isPartial ? '***************' : 'Il y a 2 semaines' }}</p>
                            </div>

                            <p class="entreprise-avis-commentaire">
                                {{ isPartial
                                    ? '********************************************************************************************************'
                                    : 'Un travail d’orfèvre sur notre sol de salon en béton ciré. L’Atelier du Béton a su nous conseiller sur la teinte parfaite. Résultat impeccable et équipe très ponctuelle.'
                                }}
                            </p>
                        </div>
                    </div>
                </section>
            </div>

            <div class="col-lg-4">
                <aside class="d-flex flex-column gap-4">
                    <div class="entreprise-contact-blanc {{ isPartial ? 'blur-content' : '' }}">
                        <div class="entreprise-contact">
                            <h3 class="entreprise-contact-titre">
                                {{ isPartial ? '**************' : 'Contact Direct' }}
                            </h3>

                            <a href="{{ isPartial ? '#' : 'tel:+33512345678' }}" class="entreprise-contact-info-devis">
                                <i class="fa-solid fa-file-invoice me-2"></i>
                                {{ isPartial ? '*****************' : 'Demander un devis' }}
                            </a>

                            <a href="{{ isPartial ? '#' : 'tel:+33512345678' }}" class="entreprise-contact-info-devis-message">
                                <i class="fa-solid fa-message me-2"></i>
                                {{ isPartial ? '********' : 'Message' }}
                            </a>
                        </div>

                        <div class="entreprise-contact-temps-reponse">
                            <p class="entreprise-contact-titre-temps">
                                <i class="fa-solid fa-clock me-2"></i>
                                {{ isPartial ? '******************************' : 'Temps de réponse moyen : ~2 heures' }}
                            </p>

                            <p class="entreprise-contact-description-temps">
                                <i class="fa-solid fa-clipboard-check me-2"></i>
                                {{ isPartial ? '****************************' : 'Projets réalisés ce mois : 8' }}
                            </p>
                        </div>
                    </div>

                    <div class="entreprise-contact-map {{ isPartial ? 'blur-content' : '' }}">
                        {{ isPartial ? '**********' : 'Google Map' }}
                    </div>
                </aside>
            </div>
        </div>
    </div>

    <div class="container-fluid g-0 mt-5">
        <div class="parallax-section d-flex align-items-center justify-content-center">
            <div class="container">
                <div class="row">
                    <div class="col-12 col-lg-7 mx-auto">
                        <div class="text-center text-white">
                            <h2>Devenez prestataire sur trouvemoi</h2>
                            <p>Inscrivez-vous et trouvez des nouveaux clients, développez votre notoriété et commencez à optimisez vos revenus dès maintenant.</p>
                            <a href="{{ path('app_register') }}">Commencer</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

{% endblock %}

{% block css %}
    <style>
        body {
            background: #F8F7F7;
        }

        .blur-content {
            filter: blur(8px);
            user-select: none;
            pointer-events: none;
        }
    </style>
{% endblock %}