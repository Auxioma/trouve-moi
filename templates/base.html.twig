<script>
document.addEventListener('turbo:load', function () {
    const form = document.querySelector('.search-wrapper');

    const activityInput = document.getElementById('search-activity');
    const activityResultsBox = document.getElementById('activity-results');
    const activitySelectedInput = document.getElementById('activity_selected');
    const activityError = document.getElementById('activity-error');

    const locationInput = document.querySelector('.localisation-input');
    const locationResultsBox = document.querySelector('.localisation-results');
    const locationSelectedInput = document.getElementById('location_selected');
    const locationError = document.getElementById('location-error');
    const latInput = document.getElementById('latitude');
    const lngInput = document.getElementById('longitude');

    if (!form) {
        return;
    }

    function showError(input, errorBox, message) {
        if (input) {
            input.classList.add('is-invalid');
        }

        if (errorBox) {
            errorBox.textContent = message;
            errorBox.style.display = 'block';
        }
    }

    function clearError(input, errorBox) {
        if (input) {
            input.classList.remove('is-invalid');
        }

        if (errorBox) {
            errorBox.textContent = '';
            errorBox.style.display = 'none';
        }
    }

    /*
    |--------------------------------------------------------------------------
    | ACTIVITÉ
    |--------------------------------------------------------------------------
    */
    if (activityInput && activityResultsBox && activitySelectedInput) {
        let activityDebounceTimer;

        activityInput.addEventListener('input', function () {
            const query = this.value.trim();

            clearTimeout(activityDebounceTimer);

            activitySelectedInput.value = '';
            clearError(activityInput, activityError);

            if (query.length < 2) {
                activityResultsBox.innerHTML = '';
                activityResultsBox.style.display = 'none';
                return;
            }

            activityDebounceTimer = setTimeout(() => {
                fetch(`/ajax/search/activity?q=${encodeURIComponent(query)}`, {
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    activityResultsBox.innerHTML = '';

                    if (!Array.isArray(data) || data.length === 0) {
                        activityResultsBox.style.display = 'none';
                        return;
                    }

                    data.forEach(item => {
                        const div = document.createElement('div');
                        div.classList.add('autocomplete-item');
                        div.textContent = item.name;

                        div.addEventListener('click', function () {
                            activityInput.value = item.name;
                            activitySelectedInput.value = item.id ?? item.name ?? '1';

                            clearError(activityInput, activityError);

                            activityResultsBox.innerHTML = '';
                            activityResultsBox.style.display = 'none';
                        });

                        activityResultsBox.appendChild(div);
                    });

                    activityResultsBox.style.display = 'block';
                })
                .catch(error => {
                    console.error('Erreur AJAX activité :', error);
                    activityResultsBox.innerHTML = '';
                    activityResultsBox.style.display = 'none';
                });
            }, 300);
        });

        document.addEventListener('click', function (e) {
            if (!activityInput.contains(e.target) && !activityResultsBox.contains(e.target)) {
                activityResultsBox.innerHTML = '';
                activityResultsBox.style.display = 'none';
            }
        });
    }

    /*
    |--------------------------------------------------------------------------
    | LOCALISATION
    |--------------------------------------------------------------------------
    */
    if (locationInput && locationResultsBox && locationSelectedInput) {
        let locationDebounceTimer;

        locationInput.addEventListener('input', function () {
            const query = this.value.trim();

            clearTimeout(locationDebounceTimer);

            locationSelectedInput.value = '';
            if (latInput) latInput.value = '';
            if (lngInput) lngInput.value = '';

            clearError(locationInput, locationError);

            if (query.length < 2) {
                locationResultsBox.innerHTML = '';
                locationResultsBox.style.display = 'none';
                return;
            }

            locationDebounceTimer = setTimeout(async () => {
                try {
                    const response = await fetch(`/api/cities?q=${encodeURIComponent(query)}`, {
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });

                    const cities = await response.json();

                    locationResultsBox.innerHTML = '';

                    if (!Array.isArray(cities) || cities.length === 0) {
                        locationResultsBox.style.display = 'none';
                        return;
                    }

                    cities.forEach(city => {
                        const item = document.createElement('div');
                        item.classList.add('localisation-item');
                        item.textContent = city.label ?? city.city ?? city.value ?? '';

                        item.addEventListener('click', function () {
                            locationInput.value = city.value ?? city.city ?? city.label ?? '';
                            locationSelectedInput.value = city.id ?? city.value ?? city.city ?? '1';

                            if (latInput) {
                                latInput.value = city.latitude ?? city.lat ?? '';
                            }

                            if (lngInput) {
                                lngInput.value = city.longitude ?? city.lng ?? '';
                            }

                            clearError(locationInput, locationError);

                            locationResultsBox.innerHTML = '';
                            locationResultsBox.style.display = 'none';
                        });

                        locationResultsBox.appendChild(item);
                    });

                    locationResultsBox.style.display = 'block';
                } catch (error) {
                    console.error('Erreur AJAX villes :', error);
                    locationResultsBox.innerHTML = '';
                    locationResultsBox.style.display = 'none';
                }
            }, 300);
        });

        document.addEventListener('click', function (e) {
            if (!locationInput.contains(e.target) && !locationResultsBox.contains(e.target)) {
                locationResultsBox.innerHTML = '';
                locationResultsBox.style.display = 'none';
            }
        });
    }

    /*
    |--------------------------------------------------------------------------
    | VALIDATION DU FORMULAIRE
    |--------------------------------------------------------------------------
    */
    form.addEventListener('submit', function (e) {
        let isValid = true;

        const activityValue = activityInput ? activityInput.value.trim() : '';
        const activitySelected = activitySelectedInput ? activitySelectedInput.value.trim() : '';

        const locationValue = locationInput ? locationInput.value.trim() : '';
        const locationSelected = locationSelectedInput ? locationSelectedInput.value.trim() : '';
        const latitude = latInput ? latInput.value.trim() : '';
        const longitude = lngInput ? lngInput.value.trim() : '';

        clearError(activityInput, activityError);
        clearError(locationInput, locationError);

        if (!activityValue || !activitySelected) {
            showError(activityInput, activityError, 'Veuillez choisir un métier dans la liste.');
            isValid = false;
        }

        if (!locationValue || !locationSelected || !latitude || !longitude) {
            showError(locationInput, locationError, 'Veuillez choisir une localisation dans la liste.');
            isValid = false;
        }

        if (!isValid) {
            e.preventDefault();

            const firstInvalid = document.querySelector('.is-invalid');
            if (firstInvalid) {
                firstInvalid.focus();
            }
        }
    });
});
</script>



		{% endblock %}
	</body>
</html>
