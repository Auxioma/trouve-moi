<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Welcome!{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="{{ asset('plugin/owl/dist/assets/owl.carousel.min.css') }}">
    <link rel="stylesheet" href="{{ asset('plugin/owl/dist/assets/owl.theme.default.min.css') }}">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <link rel="stylesheet" href="https://use.typekit.net/deo7fww.css">
    {% block css %}{% endblock %}
    {% block stylesheets %}
        {{ importmap('app') }}
    {% endblock %}
</head>
<body>
    {{ render(controller('\\App\\Controller\\Api\\NavBarController::NavBar')) }}
    {% block body %}{% endblock %}
    {{ include('_partials/footer.html.twig') }}
    {% block javascripts %}{% endblock %}
    <script src="https://code.jquery.com/jquery-3.7.1.min.js" integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>    <script src="{{ asset('plugin/owl/dist/owl.carousel.min.js') }}"></script>
    <script>
        $('.haut').owlCarousel({
            loop: false,
            dots: false,
            margin: 32,
            nav: false,
            autoplay: true,
            autoplayTimeout: 3000,      
            autoplayHoverPause: true,   
            smartSpeed: 800,      
            responsive: {
                0: {
                    items: 1
                },
                425: {
                    items: 1
                },
                576: {
                    items: 2
                },
                768: {
                    items: 2
                },
                992: {
                    items: 3
                },
                1200: {
                    items: 4
                }
            }

        });
        $('.play').on('click',function(){
            owl.trigger('play.owl.autoplay',[1000])
        })
        $('.stop').on('click',function(){
            owl.trigger('stop.owl.autoplay')
        })
    </script>
    <script>
        document.addEventListener('turbo:load', () => {
            const owl = $('.bas');
            owl.owlCarousel({
                loop: false,
                dots: false,
                margin: 32,
                nav: false,
                autoplay: true,
                autoplayTimeout: 3000,      
                autoplayHoverPause: true,   
                smartSpeed: 800,  
                responsive: {
                    0: {
                        items: 1
                    },
                    425: {
                        items: 1
                    },
                    576: {
                        items: 2
                    },
                    768: {
                        items: 2
                    },
                    992: {
                        items: 3
                    },
                    1200: {
                        items: 4
                    }
                }
            });
        });
        $('.play').on('click',function(){
            owl.trigger('play.owl.autoplay',[1000])
        })
        $('.stop').on('click',function(){
            owl.trigger('stop.owl.autoplay')
        })
    </script>
</body>
</html>
