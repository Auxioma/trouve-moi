}

$('.play-haut').off('click').on('click', function () {
haut.trigger('play.owl.autoplay', [1000]);
});

$('.stop-haut').off('click').on('click', function () {
haut.trigger('stop.owl.autoplay');
});

$('.play-bas').off('click').on('click', function () {
bas.trigger('play.owl.autoplay', [1000]);
});

$('.stop-bas').off('click').on('click', function () {
bas.trigger('stop.owl.autoplay');
});
});
            </script>

            <script>
                document.addEventListener('turbo:load', function () {
const input = document.getElementById('search-activity');
const resultsBox = document.getElementById('activity-results');

if (! input || ! resultsBox) {
return;
}

let debounceTimer;

input.addEventListener('input', function () {
const query = this.value.trim();

clearTimeout(debounceTimer);

if (query.length < 2) {
resultsBox.innerHTML = '';
resultsBox.style.display = 'none';
return;
}

debounceTimer = setTimeout(() => {
fetch (`/ajax/search/activity?q=${
encodeURIComponent(query)
}`, {
headers: {
'X-Requested-With': 'XMLHttpRequest'
}
}).then(response => response.json()).then(data => {
resultsBox.innerHTML = '';

if (!data.length) {
resultsBox.style.display = 'none';
return;
}

data.forEach(item => {
const div = document.createElement('div');
div.classList.add('autocomplete-item');
div.textContent = item.name;

div.addEventListener('click', function () {
input.value = item.name;
resultsBox.innerHTML = '';
resultsBox.style.display = 'none';

// Si tu veux rediriger vers la page métier :
// window.location.href = '/activite/' + item.slug;
});

resultsBox.appendChild(div);
});

resultsBox.style.display = 'block';
}).catch(error => {
console.error('Erreur AJAX :', error);
resultsBox.innerHTML = '';
resultsBox.style.display = 'none';
});
}, 300);
});

document.addEventListener('click', function (e) {
if (! input.contains(e.target) && ! resultsBox.contains(e.target)) {
resultsBox.innerHTML = '';
resultsBox.style.display = 'none';
}
});
});
            </script>

 <script>
document.addEventListener('DOMContentLoaded', function () {
    const input = document.querySelector('.localisation-input');
    const resultsBox = document.querySelector('.localisation-results');
    const latInput = document.getElementById('latitude');
    const lngInput = document.getElementById('longitude');

    console.log('input:', input);
    console.log('resultsBox:', resultsBox);

    if (!input || !resultsBox) {
        console.error('Champ ou boîte de résultats introuvable.');
        return;
    }

    input.addEventListener('input', async function () {
        const query = this.value.trim();

        console.log('query:', query);

        if (query.length < 2) {
            resultsBox.innerHTML = '';
            resultsBox.style.display = 'none';

            if (latInput) latInput.value = '';
            if (lngInput) lngInput.value = '';

            return;
        }

        try {
            const response = await fetch(`/api/cities?q=${encodeURIComponent(query)}`);
            const cities = await response.json();

            console.log('cities:', cities);

            resultsBox.innerHTML = '';

            if (!Array.isArray(cities) || cities.length === 0) {
                resultsBox.style.display = 'none';
                return;
            }

            cities.forEach(city => {
                const item = document.createElement('div');
                item.classList.add('localisation-item');

                item.textContent = city.label ?? city.city ?? city.value ?? '';

                item.addEventListener('click', function () {
                    input.value = city.value ?? city.city ?? city.label ?? '';

                    if (latInput) {
                        latInput.value = city.latitude ?? city.lat ?? '';
                    }

                    if (lngInput) {
                        lngInput.value = city.longitude ?? city.lng ?? '';
                    }

                    resultsBox.innerHTML = '';
                    resultsBox.style.display = 'none';

                    console.log('Ville sélectionnée :', {
                        city: input.value,
                        latitude: latInput ? latInput.value : null,
                        longitude: lngInput ? lngInput.value : null
                    });
                });

                resultsBox.appendChild(item);
            });

            resultsBox.style.display = 'block';
        } catch (error) {
            console.error('Erreur AJAX villes :', error);
        }
    });

    document.addEventListener('click', function (e) {
        if (!input.contains(e.target) && !resultsBox.contains(e.target)) {
            resultsBox.innerHTML = '';
            resultsBox.style.display = 'none';
        }
    });
});
</script>

    {% endblock %}
    </body>
</html>
