<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Welcome!{% endblock %}</title>

    <link rel="shortcut icon" type="image/x-icon" href="{{ asset('media/favicon-dark.png') }}">
    <link rel="stylesheet" href="{{ asset('css/vendor/bootstrap.min.css') }}">
    <link rel="stylesheet" href="{{ asset('css/vendor/font-awesome.css') }}">
    <link rel="stylesheet" href="{{ asset('css/vendor/slick.css') }}">
    <link rel="stylesheet" href="{{ asset('css/vendor/slick-theme.css') }}">
    <link rel="stylesheet" href="{{ asset('css/vendor/sal.css') }}">
    <link rel="stylesheet" href="{{ asset('css/app.css') }}">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    {{ importmap('app') }}
    {% block stylesheets %}{% endblock %}
    {% if app.user %}
    <style>
        .inner-banner {
            height: clamp(250px, 26.042vw, 300px);!important;
        }
    </style>
    {% endif %}

</head>

<body class="ui-smooth-scroll">
    <div id="main-wrapper" class="main-wrapper overflow-hidden">
        <div id="scroll-container">

    {% include ('_partials/preloader.html.twig') %}

    {{ render(controller('App\\Controller\\Api\\NavBarController::NavBar')) }}

    {% block body %}{% endblock %}

    

    <!-- JS -->
    <script src="{{ asset('js/vendor/jquery-3.6.3.min.js') }}"></script>
    <script src="{{ asset('js/vendor/bootstrap.min.js') }}"></script>
    <script src="{{ asset('js/vendor/slick.min.js') }}"></script>
    <script src="{{ asset('js/vendor/jquery-appear.js') }}"></script>
    <script src="{{ asset('js/vendor/jquery-validator.js') }}"></script>
    <script src="{{ asset('js/vendor/smooth-scrollbar.js') }}"></script>
    <script src="{{ asset('js/app.js') }}"></script>
    <script>
    if (navigator.geolocation) {
    navigator.geolocation.getCurrentPosition(
        function(position) {
        console.log("Latitude: " + position.coords.latitude);
        console.log("Longitude: " + position.coords.longitude);
        },
        function(error) {
        console.log("Erreur : " + error.message);
        }
    );
    } else {
    console.log("La géolocalisation n'est pas supportée.");
    }
    </script>

</body>
</html>