loop: false,
dots: false,
margin: 32,
nav: false,
autoplay: true,
autoplayTimeout: 3000,
autoplayHoverPause: true,
smartSpeed: 800,
responsive: {
0: {
items: 1
},
425: {
items: 1
},
576: {
items: 2
},
768: {
items: 2
},
992: {
items: 3
},
1200: {
items: 4
}
}
});
