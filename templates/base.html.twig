if (bas.length) {
if (bas.hasClass('owl-loaded')) {
bas.trigger('destroy.owl.carousel');
bas.removeClass('owl-loaded');
bas.find('.owl-stage-outer').children().unwrap();
}

bas.owlCarousel({
loop: false,
