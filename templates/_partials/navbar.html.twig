<div class="bg-bleu">
    <header class="container header">
        {# Navbar #}
        <nav class="navbar navbar-expand-lg navbar-light p-0">
            <a class="navbar-brand" href="{{ path('app_home') }}">
                <img src="{{ asset('image/logo/logo.png') }}" alt="">
            </a>
            <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item active">
                        <a class="nav-link" href="{{ path('app_home') }}">Accueil</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">Features</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">Pricing</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link disabled" href="#">Disabled</a>
                    </li>
                </ul>
            </div>
            <div class="auth d-none d-lg-block">
                <a href="#" class="btn-connection">Connexion</a>
                <a href="#" class="btn-commencer">Commencer</a>
            </div>
        </nav>
        {% if isHome is defined and isHome %}
            {# Text pulicitaire CTA #}
            <div class="container cta">
                <div class="row">
                    <div class="col-12 col-lg 9 col-xl-7 mx-auto mb-24">
                        <h1>L'excellence artisanale <span>à votre portée</span></h1>
                        <p>Trouvez les meilleurs experts certifiés pour vos projets d'architecture et de rénovation. Une sélection rigoureuse pour une tranquillité d'esprit totale.</p>
                    </div>
                </div>
            </div>

            {# les boutons de recherches #}
            <div class="container d-flex align-items-center justify-content-center mb-64">
                <div class="row w-100">
                    <div class="col-12 col-lg-10 mx-auto">
                        <form action="#" class="search-wrapper d-flex flex-column flex-lg-row align-items-stretch align-items-lg-center bg-white border-5 br-32">

                            <div class="recherche-artisan w-100">
                                <i class="fas fa-search"></i>
                                <input type="text" placeholder="Quel artisan cherchez-vous ?" class="recherche">
                            </div>

                            <div class="localisation w-100">
                                <i class="fas fa-map-marker-alt icon"></i>

                                <input
                                    type="text"
                                    class="localisation-input"
                                    placeholder="Localisation"
                                >

                                <button type="submit" class="localisation-btn">
                                    <i class="bi bi-search"></i>
                                    Rechercher
                                </button>
                            </div>

                        </form>
                    </div>
                </div>
            </div>

            {# les 3 images de présentation #}
            <div class="container pb-5">
                <div class="row">
                    <div class="col-12 col-md-4 pb-3 pb-md-0">
                        <img src="{{ asset('image/cta/01.png') }}" alt="" class="img-fluid w-100">
                    </div>
                    <div class="col-12 col-md-4 pb-3 pb-md-0">
                        <img src="{{ asset('image/cta/02.png') }}" alt="" class="img-fluid w-100">
                    </div>
                    <div class="col-12 col-md-4 pb-3 pb-md-0">
                        <img src="{{ asset('image/cta/03.png') }}" alt="" class="img-fluid w-100">
                    </div>
                </div>
            </div>

            {# les 3 petites images #}
            <div class="col-md-6 col-lg-5 col-xl-4 mx-auto pb-5">
                <div class="d-flex align-items-center justify-content-center flex-nowrap text-center">
                    <div class="d-flex flex-shrink-0">
                        <img src="{{ asset('image/cta/10.png') }}" class="rounded-circle border border-white" style="width:40px;">
                        <img src="{{ asset('image/cta/11.png') }}" class="rounded-circle border border-white" style="width:40px; margin-left:-20px;">
                        <img src="{{ asset('image/cta/11.png') }}" class="rounded-circle border border-white" style="width:40px; margin-left:-20px;">
                    </div>
                    <span class="ms-2">
                        1,200+ artisans vérifiés ce mois-ci
                    </span>
                </div>
            </div>
        {% endif %}
    </header>
</div>
