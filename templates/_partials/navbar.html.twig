<div class="bg-bleu">
	<header class="container header">
		<nav class="navbar navbar-expand-lg navbar-light p-0">
			<a class="navbar-brand" href="{{ path('app_home') }}">
				<img src="{{ asset('image/logo/logo.png') }}" alt="Logo">
			</a>

			<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
				<span class="navbar-toggler-icon"></span>
			</button>

			<div class="collapse navbar-collapse" id="navbarNav">
				<ul class="navbar-nav mx-auto">
					<li class="nav-item active">
						<a class="nav-link" href="{{ path('app_home') }}">
							{{ 'header.menu.home'|trans }}
						</a>
					</li>

					<li class="nav-item">
						<a class="nav-link" href="#">
							{{ 'header.menu.features'|trans }}
						</a>
					</li>

					<li class="nav-item">
						<a class="nav-link" href="#">
							{{ 'header.menu.pricing'|trans }}
						</a>
					</li>

					<li class="nav-item">
						<a class="nav-link disabled" href="#">
							{{ 'header.menu.disabled'|trans }}
						</a>
					</li>
				</ul>
			</div>

			<div class="auth d-none d-lg-block">
				<a href="{{ path('app_login') }}" class="btn-connection">
					{{ 'header.auth.login'|trans }}
				</a>

				<a href="{{ path('user_registration_app_register') }}" class="btn-commencer">
					{{ 'header.auth.start'|trans }}
				</a>
			</div>
		</nav>

		{% if isHome is defined and isHome %}
			<div class="container cta">
				<div class="row">
					<div class="col-12 col-lg-9 col-xl-7 mx-auto mb-24">

						<h1>
							{{ 'header.hero.title'|trans }}
							<span>{{ 'header.hero.title_span'|trans }}</span>
						</h1>

						<p>
							{{ 'header.hero.description'|trans }}
						</p>

					</div>
				</div>
			</div>

			<div class="container d-flex align-items-center justify-content-center mb-64">
				<div class="row w-100">
					<div class="col-12 col-lg-10 mx-auto">

						<form action="{{ path('app_category') }}" method="get" class="search-wrapper bg-white border-5 br-32 position-relative" novalidate>

							<div class="search-group search-group-activity">
								<div class="recherche-artisan position-relative">
									<i class="fas fa-search"></i>

									<input
										type="text"
										id="search-activity"
										name="activity"
										placeholder="{{ 'header.search.activity_placeholder'|trans }}"
										class="recherche"
										autocomplete="off"
									>

									<input type="hidden" name="activity_selected" id="activity_selected" value="">

									<div id="activity-results" class="autocomplete-results"></div>
								</div>

								<div id="activity-error" class="search-error-message"></div>
							</div>

							<div class="search-group search-group-location">
								<div class="localisation position-relative">

									<i class="fas fa-map-marker-alt icon"></i>

									<input
										type="text"
										class="localisation-input"
										name="location"
										placeholder="{{ 'header.search.location_placeholder'|trans }}"
										autocomplete="off"
									>

									<input type="hidden" name="location_selected" id="location_selected" value="">
									<input type="hidden" name="latitude" id="latitude">
									<input type="hidden" name="longitude" id="longitude">

									<div class="localisation-results"></div>

									<button type="submit" class="localisation-btn">
										<i class="bi bi-search"></i>

										{{ 'header.search.button'|trans }}
									</button>

								</div>

								<div id="location-error" class="search-error-message"></div>
							</div>

						</form>

					</div>
				</div>
			</div>

			<div class="container pb-5">
				<div class="row">

					<div class="col-12 col-md-4 pb-3 pb-md-0">
						<img src="{{ asset('image/cta/01.png') }}" alt="" class="img-fluid w-100">
					</div>

					<div class="col-12 col-md-4 pb-3 pb-md-0">
						<img src="{{ asset('image/cta/02.png') }}" alt="" class="img-fluid w-100">
					</div>

					<div class="col-12 col-md-4 pb-3 pb-md-0">
						<img src="{{ asset('image/cta/03.png') }}" alt="" class="img-fluid w-100">
					</div>

				</div>
			</div>

			<div class="col-md-6 col-lg-5 col-xl-4 mx-auto pb-5">
				<div class="d-flex align-items-center justify-content-center flex-nowrap text-center">

					<div class="d-flex flex-shrink-0">
						<img src="{{ asset('image/cta/10.png') }}" class="rounded-circle border border-white" style="width:40px;" alt="">
						<img src="{{ asset('image/cta/11.png') }}" class="rounded-circle border border-white" style="width:40px; margin-left:-20px;" alt="">
						<img src="{{ asset('image/cta/11.png') }}" class="rounded-circle border border-white" style="width:40px; margin-left:-20px;" alt="">
					</div>

					<span class="ms-2">
						{{ 'header.stats.artisans'|trans }}
					</span>

				</div>
			</div>
		{% endif %}
	</header>
</div>