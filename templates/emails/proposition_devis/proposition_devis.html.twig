                                </p>

                                <p class="tm-email-footer-links">
                                    <a href="{{ absolute_url(path('app_home')) }}">
                                        Accéder au site
                                    </a>
                                </p>

                            </td>
                        </tr>

                    </table>

                </td>
            </tr>
        </table>
