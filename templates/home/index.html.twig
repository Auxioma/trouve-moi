{% extends 'base.html.twig' %}

{% block title %}Hello HomeController!
{% endblock %}

{% block body %}

	<!-- banner Area start -->
	<section class="hero-sec">
		<div class="container">
			<div class="content text-center">
				<h2>Trouve un artisant</h2>
				<h2>près de chez toi</h2>
				<div class="container mt-4">
					<div class="row justify-content-center">
						<div class="col-lg-8">
							<div class="card p-4 shadow-sm">
								<form method="GET" action="/recherche">
									<div class="row g-3">

										<div class="col-md-4">
											<input type="text" name="codepostal" class="form-control" placeholder="Code postal">
										</div>

										<div class="col-md-4">
											<input type="text" name="metier" class="form-control" placeholder="Métier">
										</div>

										<div class="col-md-4">
											<button type="submit" class="btn btn-primary w-100">
												Rechercher
											</button>
										</div>

									</div>
								</form>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
		<div class="category-block">
			<div class="container">
				<div class="row justify-content-center">
					<div class="col-xl-10">
						<div class="category-slider">
							<div class="item p-1">
								<img src="{{ asset('images/label/01.png') }}" with="32" height="32" alt="">
							</div>
							<div class="item p-1">
								<img src="{{ asset('images/label/02.png') }}" with="32" height="32" alt="">
							</div>
							<div class="item p-1">
								<img src="{{ asset('images/label/03.png') }}" with="32" height="32" alt="">
							</div>
							<div class="item p-1">
								<img src="{{ asset('images/label/04.png') }}" with="32" height="32" alt="">
							</div>
							<div class="item p-1">
								<img src="{{ asset('images/label/05.png') }}" with="32" height="32" alt="">
							</div>
							<div class="item p-1">
								<img src="{{ asset('images/label/03.png') }}" with="32" height="32" alt="">
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
	<!-- banner Area end -->

	<!-- check out Area start -->
	<section class="check-out bg-gray pt-50 pb-100">
		<div class="container">
			<div class="heading">
				<h2>Trouvez un artisan de confiance près de chez vous</h2>
				<p>Des artisans labellisés Trouvemoi, sélectionnés pour la qualité de leur travail.</p>
			</div>
			<div class="property-slider">

				{% for item in lastUser %}

					<div class="content">
						<div class="img-block position-relative ">
							{% set firstPicture = item.pictures|first %}

							{% if firstPicture %}
								<img src="{{ vich_uploader_asset(firstPicture, 'imageFile') }}" alt="">
							{% else %}
								<img src="/images/no-image.jpg" alt="">
							{% endif %}

							<span>{{ item.city }}</span>
						</div>
						<a href="{{ path('app_company', {
							codePostal: item.postalCode,
							ville: item.city|lower|replace({' ': '-'}),
							slug: item.slug
						}) }}" class="title-text">{{ item.compagny }}</p>
						<ul class="list-unstyled">
							<li>
								{{ item.description|u.truncate(80) }}
							</li>
						</ul>
						<a href="{{ path('app_company', {
							codePostal: item.postalCode,
							ville: item.city|lower|replace({' ': '-'}),
							slug: item.slug
						}) }}" class="real-btn bordered text-capitalize mb-0">{{ item.activity.name }}</a>
					</div>

				{% endfor %}
			</div>
		</div>
	</section>
	<!-- check out Area end -->

	<!-- solution Area start -->
	<section class="solution bg-white p-100">
		<div class="container">
			<div class="heading">
				<h2 class="">Fonctionnalité prenium</h2>
				<p>
					Accédez à des outils avancés pour mettre en valeur votre activité, 
					                            gagner en visibilité, attirer plus de clients et gérer vos annonces 
					                            de manière professionnelle grâce à nos fonctionnalités premium.
				</p>
			</div>
			<div class="row">
				<div class="col-lg-3 col-md-6 col-12">
					<div class="content text-center">
						<img src="/media/icon/house-icon-2.png" class="mb-24" alt="">
						<h4 class="fw-6 fs-33 font-sec color-dark-3 mb-16">Demandez votre devis</h4>
						<p class="fs-16 color-gray-4 font-sec lh-130 mb-24">Discover a hassle-free way to buy, sell, or rent your dream property with
						</p>
