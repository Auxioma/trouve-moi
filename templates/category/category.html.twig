{% extends 'base.html.twig' %}

{% block title %}Hello CategoryController!{% endblock %}

{% block body %}
    <div class="bg-gris category-page">
        <div class="container">
            <div class="row pb-4">

                {# COLONNE LISTE #}
                <div class="col-12 col-lg-6">
                    <div class="row">
                        <div class="col-12 liste-des-filtres">
                            <a href="#">Catégories</a>
                            <a href="#">Localisation</a>
                            <a href="#">Disponibilité</a>
                            <a href="#">Filtres</a>
                        </div>
                    </div>

                    <div class="row">
                        <div class="assenceur">
                            {% for item in search %}
                                <div class="col-12 mb-1">
                                    <div class="category-card">
                                        <div class="category-card-image">
                                            <img src="{{ vich_uploader_asset(item, 'imageFile') ?: asset('image/artisan/01.png') }}" alt="" width="150" height="150">
                                        </div>

                                        <div class="artisan-card js-artisan-distance"
                                            data-id="{{ item.id }}"
                                            data-client-lat="{{ clientLatitude|default('') }}"
                                            data-client-lng="{{ clientLongitude|default('') }}"
                                            data-artisan-lat="{{ item.latitude|default('') }}"
                                            data-artisan-lng="{{ item.longitude|default('') }}">
                                            <h3>
                                                {% if item.compagny is not empty %}
                                                    {% if item.compagny != 'N/A' %}
                                                        {{ item.compagny|u.truncate(25, '...') }}
                                                    {% else %}
                                                        {{ item.firstname }} 
                                                    {% endif %}
                                                {% endif %}                                            
                                            </h3>
                                            <p>Spécialiste Maison Connectée</p>

                                            <div class="category-card-tags">
                                                <span>{{ item.activity.name }}</span>
                                                <span>QUALIBAT RGE</span>
                                            </div>

                                            <div class="category-card-infos mt-3">
