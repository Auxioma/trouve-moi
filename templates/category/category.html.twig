                        </div>
                    </div>
                </div>

                {# COLONNE CARTE DESKTOP #}
                <div class="col-lg-6 mt-36 d-none d-lg-block">
                    <div class="map-desktop-wrapper">
                        <div id="map"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# BARRE FLOTTANTE MOBILE #}
    <div class="mobile-action-bar d-lg-none">
        <div class="mobile-action-bar-inner">
            <button
                type="button"
                class="mobile-action-btn"
                data-bs-toggle="modal"
                data-bs-target="#mobileMapModal"
            >
                <span class="mobile-action-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M15 5L9 3L3 5V19L9 17L15 19L21 17V3L15 5ZM15 5V19M9 3V17" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </span>
                <span>Map</span>
            </button>

            <div class="mobile-action-divider"></div>

            <button
                type="button"
                class="mobile-action-btn"
                data-bs-toggle="modal"
                data-bs-target="#sortModal"
            >
                <span class="mobile-action-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M7 6H21M7 12H16M7 18H11M3 6V6.01M3 12V12.01M3 18V18.01" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </span>
                <span>Sort</span>
            </button>
        </div>
    </div>

    {# MODAL CARTE MOBILE #}
    <div class="modal fade" id="mobileMapModal" tabindex="-1" aria-labelledby="mobileMapModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-fullscreen-sm-down modal-lg">
            <div class="modal-content mobile-map-modal-content">
                <div class="modal-header border-0">
                    <h5 class="modal-title" id="mobileMapModalLabel">Carte</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                </div>
                <div class="modal-body p-0">
                    <div id="mobile-map"></div>
                </div>
            </div>
        </div>
    </div>

    {# MODAL TRI #}
    <div class="modal fade" id="sortModal" tabindex="-1" aria-labelledby="sortModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header border-0">
                    <h5 class="modal-title" id="sortModalLabel">Trier les résultats</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                </div>
                <div class="modal-body">
                    <div class="d-flex flex-column gap-2">
                        <button type="button" class="btn btn-light text-start">Les plus proches</button>
                        <button type="button" class="btn btn-light text-start">Les mieux notés</button>
                        <button type="button" class="btn btn-light text-start">Prix croissant</button>
                        <button type="button" class="btn btn-light text-start">Prix décroissant</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="container-fluid g-0 mt-5">
        <div class="parallax-section d-flex align-items-center justify-content-center">
            <div class="container">
                <div class="row">
                    <div class="col-12 col-lg-7 mx-auto">
                        <div class="text-center text-white">
                            <h2>Devenez prestataire sur trouvemoi</h2>
                            <p>Inscrivez-vous et trouvez des nouveaux clients, développez votre notoriété et commencez à optimisez vos revenus dès maintenant.</p>
                            <a href="#">Commencer</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block css %}
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
{% endblock %}

{% block javascripts %}
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const artisanCards = document.querySelectorAll('.js-artisan-distance');

        if (!artisanCards.length) {
            return;
        }

        const points = [];
        let clientPosition = null;

        artisanCards.forEach((card, index) => {
            const clientLat = parseFloat(card.dataset.clientLat);
            const clientLng = parseFloat(card.dataset.clientLng);
            const artisanLat = parseFloat(card.dataset.artisanLat);
            const artisanLng = parseFloat(card.dataset.artisanLng);
            const artisanId = card.dataset.id;

            if (!isNaN(clientLat) && !isNaN(clientLng) && !clientPosition) {
                clientPosition = [clientLat, clientLng];
            }

            if (!isNaN(artisanLat) && !isNaN(artisanLng)) {
                points.push({
                    id: artisanId,
                    coords: [artisanLat, artisanLng]
                });
            }
        });

        if (!clientPosition || !points.length) {
            return;
        }

        function buildMap(containerId) {
            const map = L.map(containerId).setView(clientPosition, 10);

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; OpenStreetMap contributors'
            }).addTo(map);

            const bounds = [];

            // Marker client
            L.marker(clientPosition)
                .addTo(map)
                .bindPopup('Votre position');

            bounds.push(clientPosition);

            // Markers artisans
            points.forEach((point, index) => {
                L.marker(point.coords)
                    .addTo(map)
                    .bindPopup('Artisan #' + point.id);

                bounds.push(point.coords);
            });

            // Cercle de 50 km autour du client
            L.circle(clientPosition, {
                radius: 50000,
                color: '#003EC7',
                fillColor: '#003EC7',
                fillOpacity: 0.08
            }).addTo(map);

            map.fitBounds(bounds, {
                padding: [50, 50]
            });

            return map;
        }

        let mobileMap = null;

        if (document.getElementById('map')) {
            buildMap('map');
        }

        const mobileModal = document.getElementById('mobileMapModal');

        if (mobileModal) {
            mobileModal.addEventListener('shown.bs.modal', function () {
                if (!mobileMap) {
                    mobileMap = buildMap('mobile-map');
                }

                setTimeout(() => {
                    mobileMap.invalidateSize();
                }, 200);
            });
        }
    });
</script>

    <script>
    function distanceKm(lat1, lon1, lat2, lon2) {
        const earthRadius = 6371;

        const dLat = (lat2 - lat1) * Math.PI / 180;
        const dLon = (lon2 - lon1) * Math.PI / 180;

        const a =
            Math.sin(dLat / 2) * Math.sin(dLat / 2) +
            Math.cos(lat1 * Math.PI / 180) *
            Math.cos(lat2 * Math.PI / 180) *
            Math.sin(dLon / 2) * Math.sin(dLon / 2);

        const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));

        return earthRadius * c;
    }

    document.addEventListener('DOMContentLoaded', function () {
        const cards = document.querySelectorAll('.js-artisan-distance');

        cards.forEach(function (card) {
            const id = card.dataset.id;
            const clientLat = parseFloat(card.dataset.clientLat);
            const clientLng = parseFloat(card.dataset.clientLng);
            const artisanLat = parseFloat(card.dataset.artisanLat);
            const artisanLng = parseFloat(card.dataset.artisanLng);

            const distanceElement = document.getElementById('distance-' + id);

            if (
                !isNaN(clientLat) &&
                !isNaN(clientLng) &&
                !isNaN(artisanLat) &&
                !isNaN(artisanLng)
            ) {
                const distance = distanceKm(clientLat, clientLng, artisanLat, artisanLng);
                distanceElement.textContent = distance.toFixed(1) + ' km';
            } else {
                distanceElement.textContent = 'Distance indisponible';
            }
        });
    });
</script>
{% endblock %}
