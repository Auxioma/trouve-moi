{% extends 'base.html.twig' %}

{% block title %}Hello CategoryController!{% endblock %}

{% block body %}
	<div class="bg-gris category-page">
		<div class="container">
			<div class="row pb-4">

				{# COLONNE LISTE #}
				<div class="col-12 col-lg-6">
					<div class="row">
						<div class="col-12 liste-des-filtres">
							<a href="#">Catégories</a>
							<a href="#">Localisation</a>
							<a href="#">Disponibilité</a>
							<a href="#">Filtres</a>
						</div>
					</div>

					<div class="row">
						<div class="assenceur">
							{% for i in 1..20 %}
								<div class="col-12 mb-1">
									<div class="category-card">
										<div class="category-card-image">
											<img src="{{ asset('image/category/01.jpg') }}" alt="">
										</div>

										<div class="category-card-content">
											<h3>Plombier {{ i }}</h3>
											<p>Spécialiste Maison Connectée</p>

											<div class="category-card-tags">
												<span>ÉBÉNISTERIE</span>
												<span>QUALIBAT RGE</span>
											</div>

											<div class="category-card-infos">
												<div class="prix">
													<svg width="17" height="12" viewBox="0 0 17 12" fill="none" xmlns="http://www.w3.org/2000/svg">
														<path d="M9.75 6.75C9.125 6.75 8.59375 6.53125 8.15625 6.09375C7.71875 5.65625 7.5 5.125 7.5 4.5C7.5 3.875 7.71875 3.34375 8.15625 2.90625C8.59375 2.46875 9.125 2.25 9.75 2.25C10.375 2.25 10.9062 2.46875 11.3438 2.90625C11.7812 3.34375 12 3.875 12 4.5C12 5.125 11.7812 5.65625 11.3438 6.09375C10.9062 6.53125 10.375 6.75 9.75 6.75ZM4.5 9C4.0875 9 3.73438 8.85312 3.44062 8.55937C3.14687 8.26562 3 7.9125 3 7.5V1.5C3 1.0875 3.14687 0.734375 3.44062 0.440625C3.73438 0.146875 4.0875 0 4.5 0H15C15.4125 0 15.7656 0.146875 16.0594 0.440625C16.3531 0.734375 16.5 1.0875 16.5 1.5V7.5C16.5 7.9125 16.3531 8.26562 16.0594 8.55937C15.7656 8.85312 15.4125 9 15 9H4.5ZM6 7.5H13.5C13.5 7.0875 13.6469 6.73438 13.9406 6.44063C14.2344 6.14688 14.5875 6 15 6V3C14.5875 3 14.2344 2.85313 13.9406 2.55938C13.6469 2.26562 13.5 1.9125 13.5 1.5H6C6 1.9125 5.85312 2.26562 5.55937 2.55938C5.26562 2.85313 4.9125 3 4.5 3V6C4.9125 6 5.26562 6.14688 5.55937 6.44063C5.85312 6.73438 6 7.0875 6 7.5ZM14.25 12H1.5C1.0875 12 0.734375 11.8531 0.440625 11.5594C0.146875 11.2656 0 10.9125 0 10.5V2.25H1.5V10.5H14.25V12ZM4.5 7.5V1.5V7.5Z" fill="#5F5E5E"/>
													</svg>
													€70/hr
												</div>

												<div class="distance">
													<svg width="12" height="15" viewBox="0 0 12 15" fill="none" xmlns="http://www.w3.org/2000/svg">
														<path d="M6 7.5C6.4125 7.5 6.76562 7.35312 7.05937 7.05937C7.35312 6.76562 7.5 6.4125 7.5 6C7.5 5.5875 7.35312 5.23438 7.05937 4.94063C6.76562 4.64688 6.4125 4.5 6 4.5C5.5875 4.5 5.23438 4.64688 4.94063 4.94063C4.64688 5.23438 4.5 5.5875 4.5 6C4.5 6.4125 4.64688 6.76562 4.94063 7.05937C5.23438 7.35312 5.5875 7.5 6 7.5ZM6 13.0125C7.525 11.6125 8.65625 10.3406 9.39375 9.19687C10.1313 8.05312 10.5 7.0375 10.5 6.15C10.5 4.7875 10.0656 3.67188 9.19687 2.80312C8.32812 1.93437 7.2625 1.5 6 1.5C4.7375 1.5 3.67188 1.93437 2.80312 2.80312C1.93437 3.67188 1.5 4.7875 1.5 6.15C1.5 7.0375 1.86875 8.05312 2.60625 9.19687C3.34375 10.3406 4.475 11.6125 6 13.0125ZM6 15C3.9875 13.2875 2.48438 11.6969 1.49063 10.2281C0.496875 8.75937 0 7.4 0 6.15C0 4.275 0.603125 2.78125 1.80938 1.66875C3.01562 0.55625 4.4125 0 6 0C7.5875 0 8.98438 0.55625 10.1906 1.66875C11.3969 2.78125 12 4.275 12 6.15C12 7.4 11.5031 8.75937 10.5094 10.2281C9.51562 11.6969 8.0125 13.2875 6 15Z" fill="#94A3B8"/>
													</svg>
													1,4 km
												</div>
											</div>
										</div>
									</div>
								</div>
							{% endfor %}
						</div>
					</div>
				</div>

				{# COLONNE CARTE DESKTOP #}
				<div class="col-lg-6 mt-36 d-none d-lg-block">
					<div class="map-desktop-wrapper">
						<div id="map"></div>
					</div>
				</div>
			</div>
		</div>
	</div>

	{# BARRE FLOTTANTE MOBILE #}
	<div class="mobile-action-bar d-lg-none">
		<div class="mobile-action-bar-inner">
			<button
				type="button"
				class="mobile-action-btn"
				data-bs-toggle="modal"
				data-bs-target="#mobileMapModal"
			>
				<span class="mobile-action-icon">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
						<path d="M15 5L9 3L3 5V19L9 17L15 19L21 17V3L15 5ZM15 5V19M9 3V17" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
					</svg>
				</span>
				<span>Map</span>
			</button>

			<div class="mobile-action-divider"></div>

			<button
				type="button"
				class="mobile-action-btn"
				data-bs-toggle="modal"
				data-bs-target="#sortModal"
			>
				<span class="mobile-action-icon">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
						<path d="M7 6H21M7 12H16M7 18H11M3 6V6.01M3 12V12.01M3 18V18.01" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
					</svg>
				</span>
				<span>Sort</span>
			</button>
		</div>
	</div>

	{# MODAL CARTE MOBILE #}
	<div class="modal fade" id="mobileMapModal" tabindex="-1" aria-labelledby="mobileMapModalLabel" aria-hidden="true">
		<div class="modal-dialog modal-dialog-centered modal-fullscreen-sm-down modal-lg">
			<div class="modal-content mobile-map-modal-content">
				<div class="modal-header border-0">
					<h5 class="modal-title" id="mobileMapModalLabel">Carte</h5>
					<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
				</div>
				<div class="modal-body p-0">
					<div id="mobile-map"></div>
				</div>
			</div>
		</div>
	</div>

	{# MODAL TRI #}
	<div class="modal fade" id="sortModal" tabindex="-1" aria-labelledby="sortModalLabel" aria-hidden="true">
		<div class="modal-dialog modal-dialog-centered">
			<div class="modal-content">
				<div class="modal-header border-0">
					<h5 class="modal-title" id="sortModalLabel">Trier les résultats</h5>
					<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
				</div>
				<div class="modal-body">
					<div class="d-flex flex-column gap-2">
						<button type="button" class="btn btn-light text-start">Les plus proches</button>
						<button type="button" class="btn btn-light text-start">Les mieux notés</button>
						<button type="button" class="btn btn-light text-start">Prix croissant</button>
						<button type="button" class="btn btn-light text-start">Prix décroissant</button>
					</div>
				</div>
			</div>
		</div>
	</div>

	<div class="container-fluid g-0 mt-5">
		<div class="parallax-section d-flex align-items-center justify-content-center">
			<div class="container">
				<div class="row">
					<div class="col-12 col-lg-7 mx-auto">
						<div class="text-center text-white">
							<h2>Devenez prestataire sur trouvemoi</h2>
							<p>Inscrivez-vous et trouvez des nouveaux clients, développez votre notoriété et commencez à optimisez vos revenus dès maintenant.</p>
							<a href="#">Commencer</a>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
{% endblock %}

{% block css %}
	<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>

	<style>
		.map-desktop-wrapper {
			height: 100%;
			min-height: 700px;
			border-radius: 24px;
			overflow: hidden;
			position: sticky;
			top: 100px;
		}

		#map {
			width: 100%;
			height: 100%;
			min-height: 700px;
		}

		#mobile-map {
			width: 100%;
			height: 70vh;
			min-height: 420px;
		}

		.mobile-map-modal-content {
			border: none;
			border-radius: 24px;
			overflow: hidden;
		}

		.mobile-action-bar {
			position: fixed;
			left: 50%;
			bottom: 20px;
			transform: translateX(-50%);
			z-index: 1060;
			width: max-content;
		}

		.mobile-action-bar-inner {
			display: flex;
			align-items: center;
			background: #FFFFFF;
			border: 1px solid #D9D9D9;
			border-radius: 12px;
			box-shadow: 0 4px 14px rgba(0, 0, 0, 0.10);
			overflow: hidden;
		}

		.mobile-action-btn {
			display: flex;
			align-items: center;
			justify-content: center;
			gap: 8px;
			min-height: 44px;
			padding: 0 18px;
			border: none;
			background: #FFFFFF;
			color: #111827;
			font-size: 16px;
			font-weight: 600;
			line-height: 1;
			cursor: pointer;
			transition: background 0.2s ease, color 0.2s ease;
		}

		.mobile-action-btn:hover,
		.mobile-action-btn:focus {
			background: #F8FAFC;
			color: #111827;
		}

		.mobile-action-btn:focus {
			outline: none;
		}

		.mobile-action-icon {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			color: #1F2937;
			flex-shrink: 0;
		}

		.mobile-action-divider {
			width: 1px;
			height: 24px;
			background: #D9D9D9;
		}

		@media (max-width: 991.98px) {
			.category-page {
				padding-bottom: 100px;
			}
		}

		@media (min-width: 992px) {
			.mobile-action-bar {
				display: none !important;
			}
		}
	</style>
{% endblock %}

{% block javascripts %}
	<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

	<script>
		document.addEventListener('DOMContentLoaded', function () {
			const paris = [48.8566, 2.3522];

			const points = [
				[48.8566, 2.3522],
				[48.9021, 2.4892],
				[48.8049, 2.1204],
				[48.6921, 2.1872],
				[48.5734, 2.3349],
				[49.0365, 2.0781],
				[48.7761, 2.1983],
				[48.9475, 2.2478],
				[48.6153, 2.4157],
				[48.7916, 2.4556],
				[48.9833, 2.6167],
				[48.7597, 2.6053],
				[48.7069, 2.4382],
				[48.9356, 2.3539],
				[48.8402, 2.5624],
				[48.6682, 2.5690],
				[48.7284, 2.2588],
				[48.9983, 2.2775],
				[48.8560, 2.6816],
				[48.6317, 2.4405],
				[48.7448, 2.3971],
				[48.8897, 2.2060],
				[48.8212, 2.2068],
				[48.9530, 2.1452],
				[48.7300, 2.3282],
				[48.6186, 2.5480],
				[48.9744, 2.5200],
				[48.7869, 2.2293],
				[48.8609, 2.4370],
				[48.7004, 2.1342]
			];

			function buildMap(containerId) {
				const map = L.map(containerId).setView(paris, 10);

				L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
					attribution: '&copy; OpenStreetMap contributors'
				}).addTo(map);

				const bounds = [];

				points.forEach((point, index) => {
					L.marker(point)
						.addTo(map)
						.bindPopup(index === 0 ? 'Paris centre' : 'Artisan #' + index);

					bounds.push(point);
				});

				L.circle(paris, {
					radius: 50000,
					color: '#003EC7',
					fillColor: '#003EC7',
					fillOpacity: 0.08
				}).addTo(map);

				map.fitBounds(bounds, {
					padding: [50, 50]
				});

				return map;
			}

			let mobileMap = null;

			if (document.getElementById('map')) {
				buildMap('map');
			}

			const mobileModal = document.getElementById('mobileMapModal');

			if (mobileModal) {
				mobileModal.addEventListener('shown.bs.modal', function () {
					if (!mobileMap) {
						mobileMap = buildMap('mobile-map');
					}

					setTimeout(() => {
						mobileMap.invalidateSize();
					}, 200);
				});
			}
		});
	</script>
{% endblock %}